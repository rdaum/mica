// LLM request helpers. Responses streams are delivered as typed events to a
// caller-owned mailbox. Chat Completions remains available as an explicit
// provider-compatibility adapter and uses the same event vocabulary.

verb llm/system_message(content @ #string)
  return {:role -> "system", :content -> content}
end

verb llm/user_message(content @ #string)
  return {:role -> "user", :content -> content}
end

verb llm/assistant_message(content @ #string)
  return {:role -> "assistant", :content -> content}
end

verb llm/tool_message(tool_call_id @ #string, content @ #string)
  return {:role -> "tool", :tool_call_id -> tool_call_id, :content -> content}
end

verb llm/responses_stream(model @ #string, input, instructions, options, tools, sender)
  let opts = llm/ensure_stream(options)
  let request_tools = tools
  if request_tools == nothing
    request_tools = []
  end
  return llm_responses_stream(model, input, instructions, opts, request_tools, sender)
end

verb llm/chat_stream(model @ #string, messages, options, tools, sender)
  let opts = llm/ensure_stream(options)
  let request_tools = tools
  if request_tools == nothing
    request_tools = []
  end
  return llm_chat_stream_to(model, messages, opts, request_tools, sender)
end

verb llm/ensure_stream(options)
  if options == nothing
    return {:stream -> true}
  end
  let opts = {:stream -> true}
  for pair in map_pairs(options)
    opts[pair[0]] = pair[1]
  end
  return opts
end
