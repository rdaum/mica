verb source/handle_sync_action(source @ #source/open_retrieval_citation_action<_>, endpoint, session, view, event, target, fields)
  if source/View(view) == false || event != "submit"
    return false
  end

  let raw_subject = fields[:subject]
  if raw_subject == nothing
    return false
  end

  let subject = from_literal(raw_subject)
  if subject == nothing || source/can_retrieve_subject(#web, subject) == false
    return false
  end

  let path = source/retrieval_text_unit_path(subject)
  let plan = one source/SelectedRetrievalPlan(endpoint, ?plan)
  let line = one source/RetrievalCitationLine(plan, subject, ?line)
  if line == nothing
    line = source/retrieval_text_unit_line(subject)
  end
  if path == nothing || source/file_for_path(path) == nothing
    return false
  end

  retract source/SelectedRepository(endpoint, _)
  retract source/SelectedRevision(endpoint, _)
  retract source/SelectedPath(endpoint, _)
  retract source/SelectedLine(endpoint, _)
  retract source/SelectedWindowStart(endpoint, _)
  assert source/SelectedRepository(endpoint, #source/repo_mica)
  assert source/SelectedRevision(endpoint, #source/rev_worktree)
  assert source/SelectedPath(endpoint, path)
  assert source/SelectedLine(endpoint, line)
  let line_count = one source/FileLineCount(#source/repo_mica, #source/rev_worktree, path, ?line_count)
  if line_count == nothing
    line_count = line
  end
  assert source/SelectedWindowStart(endpoint, source/window_start_for_line(line, line_count))
  source/bump_revision(endpoint)
  return true
end

verb source/handle_sync_action(source @ #source/toggle_hidden_action<_>, endpoint, session, view, event, target, fields)
  if source/View(view) == false || event != "submit"
    return false
  end

  let show_hidden = false
  if fields[:show_hidden] == "true"
    show_hidden = true
  end

  retract source/ShowHiddenFiles(endpoint, _)
  assert source/ShowHiddenFiles(endpoint, show_hidden)
  source/bump_revision(endpoint)
  return true
end

verb source/handle_sync_action(source @ #source/toggle_inspector_section_action<_>, endpoint, session, view, event, target, fields)
  if source/View(view) == false || event != "submit"
    return false
  end

  let section = fields[:section]
  if section != "outline" && section != "annotations"
    return false
  end

  let collapsed = false
  if fields[:collapsed] == "true"
    collapsed = true
  end

  retract source/InspectorSectionCollapsed(endpoint, section, _)
  assert source/InspectorSectionCollapsed(endpoint, section, collapsed)
  source/bump_revision(endpoint)
  return true
end
