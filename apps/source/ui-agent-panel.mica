// Source viewer Talk panel and lower tray.

verb source/agent_prompt_form_node()
  let input = dom_element("textarea", {:name -> "prompt", :class -> "source-agent-input", :placeholder -> "Ask about the current file, a symbol, or the workspace"}, [])
  let button = dom_element("button", {:type -> "submit", :class -> "source-search-button", "data-sync-disable-with" -> "Thinking"}, [dom_text("Send")])
  return dom_element("form", {:class -> "source-agent-form", "data-sync-event" -> "submit", "data-sync-action" -> "source_agent_prompt", "data-sync-key" -> "source-agent-prompt", "data-sync-reset" -> "true"}, [input, button])
end

verb source/agent_turn_citations_node(turn)
  let plan = one source/AgentTurnPlan(turn, ?plan)
  if plan == nothing
    return source/empty_node("")
  end

  let items = []
  let count = 0
  let ordinal = 1
  while ordinal <= 64 && count < 4
    for found in ContextOrdinal(?context, ordinal)
      if one ContextForPlan(found[:context], ?plan) == plan
        items = [@items, source/retrieval_context_node(found[:context])]
        count = count + 1
        break
      end
    end
    ordinal = ordinal + 1
  end

  if items == []
    return source/empty_node("")
  end

  return dom_element("details", {:class -> "source-agent-citations"}, [dom_element("summary", {}, [dom_text("Retrieved context")]), dom_element("div", {:class -> "source-agent-citations-list"}, items)])
end

verb source/agent_proposal_review_controls_node(proposal)
  let hidden = dom_element("input", {:type -> "hidden", :name -> "proposal", :value -> to_literal(proposal)}, [])
  let accept = dom_element("form", {:class -> "source-answer-review-form", "data-sync-event" -> "submit", "data-sync-action" -> "source_accept_agent_proposal", "data-sync-key" -> string_concat("accept-proposal:", to_literal(proposal))}, [hidden, dom_element("button", {:type -> "submit", :class -> "source-search-button"}, [dom_text("Accept")])])
  let reject = dom_element("form", {:class -> "source-answer-review-form", "data-sync-event" -> "submit", "data-sync-action" -> "source_reject_agent_proposal", "data-sync-key" -> string_concat("reject-proposal:", to_literal(proposal))}, [dom_element("input", {:type -> "hidden", :name -> "proposal", :value -> to_literal(proposal)}, []), dom_element("button", {:type -> "submit", :class -> "source-search-button"}, [dom_text("Reject")])])
  let body = one source/AgentProposalBody(proposal, ?body)
  if body == nothing
    body = ""
  end
  let correct = dom_element("form", {:class -> "source-answer-correction-form", "data-sync-event" -> "submit", "data-sync-action" -> "source_correct_agent_proposal", "data-sync-key" -> string_concat("correct-proposal:", to_literal(proposal))}, [dom_element("input", {:type -> "hidden", :name -> "proposal", :value -> to_literal(proposal)}, []), dom_element("textarea", {:name -> "body", :class -> "source-search-input"}, [dom_text(body)]), dom_element("button", {:type -> "submit", :class -> "source-search-button"}, [dom_text("Correct")])])
  return dom_element("div", {:class -> "source-answer-review-controls"}, [accept, reject, correct])
end

verb source/agent_proposal_node(proposal)
  let kind = one source/AgentProposalKind(proposal, ?kind)
  let title = one source/AgentProposalTitle(proposal, ?title)
  let body = one source/AgentProposalBody(proposal, ?body)
  let status = one source/AgentProposalStatus(proposal, ?status)
  if kind == nothing
    kind = "proposal"
  end
  if title == nothing
    title = "Untitled proposal"
  end
  if body == nothing
    body = ""
  end
  if status == nothing
    status = "pending"
  end
  return dom_element("article", {:class -> "source-agent-proposal"}, [dom_element("h3", {}, [dom_text(title)]), dom_element("p", {}, [dom_text(body)]), dom_element("div", {:class -> "source-search-status"}, [source/meta_chip_node("kind", kind), source/meta_chip_node("status", status)]), source/agent_proposal_review_controls_node(proposal)])
end

verb source/agent_turn_proposals_node(turn)
  let items = []
  for found in source/AgentProposalTurn(?proposal, turn)
    items = [@items, source/agent_proposal_node(found[:proposal])]
  end
  if items == []
    return source/empty_node("")
  end
  return dom_element("section", {:class -> "source-agent-proposals"}, items)
end

verb source/agent_turn_reasoning_node(turn)
  let reasoning = one source/AgentTurnReasoning(turn, ?reasoning)
  if reasoning == nothing || reasoning == ""
    return source/empty_node("")
  end
  return dom_element("details", {:class -> "source-agent-reasoning"}, [dom_element("summary", {}, [dom_text("Thinking")]), dom_element("pre", {:class -> "source-agent-reasoning-text"}, [dom_text(reasoning)])])
end

verb source/agent_tool_summary_text(tool @ #string, args)
  if args == nothing
    return ""
  end

  if tool == "source_search"
    let query = args[:query]
    if query == nothing
      query = ""
    end
    let scope = args[:scope]
    if scope == nothing || scope == ""
      scope = "all"
    end
    return string_concat("query: ", query, " / scope: ", scope)
  end

  if tool == "source_file_window"
    let path = args[:path]
    if path == nothing || path == ""
      path = "current file"
    end
    let start_line = args[:start_line]
    if start_line == nothing
      start_line = 1
    end
    let line_count = args[:line_count]
    if line_count == nothing
      line_count = 120
    end
    return string_concat(path, ":", to_literal(start_line), " +", to_literal(line_count), " lines")
  end

  if tool == "source_symbol_context"
    let query = args[:query]
    if query != nothing && query != ""
      return string_concat("query: ", query)
    end
    let path = args[:path]
    let byte_offset = args[:byte_offset]
    if path != nothing && path != "" && byte_offset != nothing
      return string_concat(path, " @ byte ", to_literal(byte_offset))
    end
    return "current symbol"
  end

  if tool == "source_find_references"
    let query = args[:query]
    if query != nothing && query != ""
      return string_concat("query: ", query)
    end
    let symbol = args[:symbol]
    if symbol != nothing && symbol != ""
      return string_concat("symbol: ", symbol)
    end
    return "current symbol"
  end

  if tool == "mica_query"
    let query = args[:query]
    if query != nothing && query != ""
      return query
    end
  end

  return to_literal(args)
end

verb source/agent_tool_node(request)
  let ordinal = nothing
  let tool = "unknown"
  let status = "running"
  let args = nothing
  for found in source/AgentToolRequest(request, ?request_ordinal, ?request_tool, ?request_args, ?request_status)
    ordinal = found[:request_ordinal]
    tool = found[:request_tool]
    args = found[:request_args]
    status = found[:request_status]
    break
  end

  let transcript = one source/AgentToolTranscriptText(request, ?text)
  if transcript == nothing
    transcript = string_concat("arguments: ", to_literal(args))
  end
  let summary = string_concat(to_literal(ordinal), ". ", tool)
  let detail = source/agent_tool_summary_text(tool, args)
  let heading_children = [dom_element("span", {:class -> "source-agent-tool-name"}, [dom_text(summary)])]
  if detail != ""
    heading_children = [@heading_children, dom_element("span", {:class -> "source-agent-tool-detail"}, [dom_text(detail)])]
  end
  heading_children = [@heading_children, source/meta_chip_node("status", status)]
  let heading = dom_element("summary", {:class -> "source-agent-tool-heading"}, heading_children)
  let body = dom_element("pre", {:class -> "source-agent-tool-text"}, [dom_text(transcript)])
  return dom_element("details", {:class -> string_concat("source-agent-tool source-agent-tool-", status), "data-sync-key" -> to_literal(request)}, [heading, body])
end

verb source/agent_turn_tools_node(turn)
  let items = []
  let count = 0
  let ordinal = 1
  while ordinal <= 64 && count < 16
    for found in source/AgentToolCallForTurn(?request, turn)
      let request = found[:request]
      let request_row = one source/AgentToolRequest(request, ?request_ordinal, ?tool, ?args, ?status)
      if request_row[:request_ordinal] == ordinal
        items = [@items, source/agent_tool_node(request)]
        count = count + 1
        break
      end
    end
    ordinal = ordinal + 1
  end

  if items == []
    return source/empty_node("")
  end
  return dom_element("details", {:class -> "source-agent-tools"}, [dom_element("summary", {}, [dom_text("Tool activity")]), dom_element("div", {:class -> "source-agent-tool-list"}, items)])
end

verb source/agent_turn_node(turn)
  let role = one source/AgentTurnRole(turn, ?role)
  let text = one source/AgentTurnText(turn, ?text)
  let status = one source/AgentTurnStatus(turn, ?status)
  let model = one source/AgentTurnResolvedModel(turn, ?model)
  if role == nothing
    role = "assistant"
  end
  if text == nothing
    text = ""
  end
  if status == nothing
    status = "complete"
  end

  let meta = [source/meta_chip_node("status", status)]
  if model != nothing
    meta = [@meta, source/meta_chip_node("model", model)]
  end

  let children = [dom_element("div", {:class -> "source-agent-turn-role"}, [dom_text(role)]), dom_element("div", {:class -> "source-agent-turn-text"}, [dom_text(text)]), dom_element("div", {:class -> "source-search-status"}, meta)]
  if role == "assistant"
    children = [@children, source/agent_turn_reasoning_node(turn)]
    children = [@children, source/agent_turn_tools_node(turn)]
    children = [@children, source/agent_turn_citations_node(turn)]
    children = [@children, source/agent_turn_proposals_node(turn)]
  end

  return dom_element("article", {:class -> string_concat("source-agent-turn source-agent-turn-", role), "data-sync-key" -> to_literal(turn)}, children)
end

verb source/agent_pending_turn_node()
  return dom_element("article", {:class -> "source-agent-turn source-agent-turn-assistant source-agent-turn-pending", "data-sync-key" -> "agent-processing"}, [dom_element("div", {:class -> "source-agent-turn-role"}, [dom_text("assistant")]), dom_element("div", {:class -> "source-agent-turn-text"}, [dom_text("Processing...")]), dom_element("div", {:class -> "source-search-status"}, [source/meta_chip_node("status", "working")])])
end

verb source/agent_turn_list_node()
  let turns = []
  let count = 0
  let ordinal = 1
  while ordinal <= 64 && count < 8
    for found in source/AgentTurnEndpoint(?turn, endpoint())
      let turn = found[:turn]
      let turn_ordinal = one source/AgentTurnOrdinal(turn, ?ordinal)
      if turn_ordinal == ordinal
        turns = [@turns, source/agent_turn_node(turn)]
        count = count + 1
        if count >= 8
          break
        end
      end
    end
    ordinal = ordinal + 1
  end

  let status = one source/SelectedAgentStatus(endpoint(), ?status)
  if status == "working"
    turns = [@turns, source/agent_pending_turn_node()]
  end

  if turns == []
    return source/empty_node("Ask about the current source context.")
  end

  return dom_element("div", {:class -> "source-agent-turn-list"}, turns)
end

verb source/agent_turn_count(endpoint)
  let count = 0
  for found in source/AgentTurnEndpoint(?turn, endpoint)
    count = count + 1
  end
  return count
end

verb source/agent_panel_node()
  let status = one source/SelectedAgentStatus(endpoint(), ?status)
  let class = "source-agent-panel"
  if status == "working"
    class = "source-agent-panel working"
  end
  let children = [dom_element("h2", {}, [dom_text("Talk")]), source/agent_turn_list_node()]
  if status != nothing
    children = [@children, dom_element("div", {:class -> "source-search-status"}, [source/meta_chip_node("agent", status)])]
  end
  children = [@children, source/agent_prompt_form_node()]
  return dom_element("section", {:class -> class}, children)
end

verb source/code_tray_tab()
  let selected = one source/SelectedCodeTrayTab(endpoint(), ?tab)
  if selected != nothing
    return source/normalise_code_tray_tab(selected)
  end

  if source/current_symbol() != nothing
    return "symbol"
  end

  return "talk"
end

verb source/code_tray_tab_button_node(value, label, active)
  let class = "source-code-tray-tab"
  let selected = "false"
  if value == active
    class = "source-code-tray-tab active"
    selected = "true"
  end

  let hidden = dom_element("input", {:type -> "hidden", :name -> "tab", :value -> value}, [])
  let button = dom_element("button", {:type -> "submit", :class -> class, :role -> "tab", "aria-selected" -> selected, "data-sync-disable-with" -> label}, [dom_text(label)])
  return dom_element("form", {:class -> "source-code-tray-tab-form", "data-sync-event" -> "submit", "data-sync-action" -> "source_set_code_tray_tab", "data-sync-key" -> string_concat("code-tray:", value), "data-sync-reset" -> "false"}, [hidden, button])
end

verb source/code_tray_node(repository, revision)
  let active = source/code_tray_tab()
  let class = string_concat("source-code-tray active-", active)
  if source/agent_turn_count(endpoint()) > 0
    class = string_concat(class, " has-agent-turns")
  end

  let tabs = dom_element("div", {:class -> "source-code-tray-tabs", :role -> "tablist"}, [source/code_tray_tab_button_node("symbol", "Symbol", active), source/code_tray_tab_button_node("talk", "Talk", active)])
  let content = source/agent_panel_node()
  if active == "symbol"
    content = source/symbol_panel_node(repository, revision)
  end

  return dom_element("section", {:class -> class}, [tabs, dom_element("div", {:class -> "source-code-tray-body"}, [content])])
end
