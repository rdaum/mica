make_identity(:source/text_file_runtime)
make_identity(:source/text_file_ui_session)
make_identity(:source/text_symbol_sync_view_tree)
make_identity(:source/text_doc_comment_computed_relation)
make_identity(:source/text_markdown_phase6)
make_identity(:source/text_review_note_dom_sync)
make_identity(:source/text_design_doc_graphrag)
make_identity(:source/symbol_sync_view_tree)

make_functional_relation(:source/RetrievalTextUnitKind, 2, [0])
make_functional_relation(:source/RetrievalTextUnitTitle, 2, [0])
make_functional_relation(:source/RetrievalTextUnitFile, 2, [0])
make_functional_relation(:source/RetrievalTextUnitSpan, 2, [0])
make_functional_relation(:source/RetrievalTextUnitStartLine, 2, [0])
make_functional_relation(:source/RetrievalTextUnitEndLine, 2, [0])
make_functional_relation(:source/RetrievalTextUnitModel, 2, [0])
make_relation(:source/RetrievalCitation, 2)
make_functional_relation(:source/RetrievalCitationText, 3, [0, 1])
make_functional_relation(:source/SelectedRetrievalQuestion, 2, [0])
make_functional_relation(:source/SelectedRetrievalPlan, 2, [0])
make_functional_relation(:source/SelectedRetrievalModel, 2, [0])
make_functional_relation(:source/SelectedRetrievalLimit, 2, [0])
make_functional_relation(:source/SelectedRetrievalStatus, 2, [0])

assert VectorIndex(#source/retrieval_index)
assert VectorIndexMetric(#source/retrieval_index, "cosine")

