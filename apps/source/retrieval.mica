assert TextUnitText(#source/text_file_ui_session, "DOM sync rendered in Mica: sync_view_revision and sync_view_tree return the server-owned view tree that the host snapshots and sends to the browser.")
assert source/RetrievalTextUnitKind(#source/text_file_ui_session, "file")
assert source/RetrievalTextUnitTitle(#source/text_file_ui_session, "DOM sync view entrypoints")
