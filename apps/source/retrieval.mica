CanRetrieveSubject(actor, subject) :-
  source/RetrievalTextUnitFile(subject, file),
  source/CanReadSourceFile(actor, file)

CanRetrieveSubject(actor, subject) :-
  source/RetrievalTextUnitSpan(subject, span),
  source/CanReadSourceSpan(actor, span)

verb source/retrieval_model()
  let model = one source/RuntimeConfig(#source/config_retrieval_model, ?model)
  if model != nothing
    return model
  end

  return "source-workspace"
end

verb source/generation_model()
  let model = one source/RuntimeConfig(#source/config_agent_model, ?model)
  if model != nothing
    return model
  end

  return "deepseek/deepseek-v4-pro"
end

verb source/generation_provider()
  let provider = one source/RuntimeConfig(#source/config_generation_provider, ?provider)
  if provider != nothing
    return provider
  end

  return "openrouter"
end

verb source/retrieval_limit()
  let limit = one source/RuntimeConfig(#source/config_retrieval_limit, ?limit)
  if limit != nothing
    return limit
  end

  return 8
end

verb source/agent_file_context_line_limit()
  let limit = one source/RuntimeConfig(#source/config_agent_file_context_line_limit, ?limit)
  if limit != nothing && limit > 0
    return limit
  end

  return 20000
end

verb source/default_retrieval_scope()
  return "all"
end

verb source/normalise_retrieval_scope(scope)
  if scope == "docs" || scope == "code" || scope == "tests" || scope == "benches" || scope == "sketches"
    return scope
  end

  return "all"
end

verb source/retrieval_corpus_version()
  for index_row in source/SourceIndex(?index)
    let candidate = one source/IndexVersion(index_row[:index], ?version)
    if candidate != nothing
      return candidate
    end
  end

  return "worktree"
end

verb source/retrieval_text_unit_path(unit)
  for indexed in source/IndexedTextUnit(unit, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return indexed[:path]
  end

  let file = one source/RetrievalTextUnitFile(unit, ?file)
  if file == nothing
    return nothing
  end

  return one source/FilePath(file, ?path)
end

verb source/retrieval_text_unit_line(unit)
  for indexed in source/IndexedTextUnit(unit, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return indexed[:start_line]
  end

  let line = one source/RetrievalTextUnitStartLine(unit, ?line)
  if line == nothing
    return 1
  end

  return line
end

verb source/retrieval_text_unit_title(unit)
  for indexed in source/IndexedTextUnit(unit, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return indexed[:title]
  end

  return one source/RetrievalTextUnitTitle(unit, ?title)
end

verb source/retrieval_text_unit_kind(unit)
  for indexed in source/IndexedTextUnit(unit, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return indexed[:kind]
  end

  return one source/RetrievalTextUnitKind(unit, ?kind)
end

verb source/retrieval_text_unit_text(unit)
  for indexed in source/IndexedTextUnit(unit, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return indexed[:text]
  end

  return one TextUnitText(unit, ?text)
end

verb source/can_retrieve_subject(actor, subject)
  if source/CanBrowseRepository(actor, #source/repo_mica) == false
    return false
  end

  for indexed in source/IndexedTextUnit(subject, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?model, ?text)
    return true
  end

  if one source/RetrievalTextUnitFile(subject, ?file) != nothing
    return true
  end

  if one source/RetrievalTextUnitSpan(subject, ?span) != nothing
    return true
  end

  return false
end

verb source/retrieval_subject_status(subject, model @ #string)
  let text = source/retrieval_text_unit_text(subject)
  if text == nothing
    return "missing"
  end

  return retrieval/index_entry_status(#source/retrieval_index, subject, model, text)
end

verb source/retrieval_corpus_ready(model @ #string)
  let has_complete_corpus = false
  for index_row in source/SourceIndex(?index)
    let status = one source/IndexStatus(index_row[:index], ?status)
    if status == "complete"
      has_complete_corpus = true
      break
    end
  end
  if has_complete_corpus == false
    return true
  end

  let corpus_version = source/retrieval_corpus_version()
  let indexed_version = one source/RetrievalCorpusIndexVersion(#source/retrieval_index, model, ?version)
  return indexed_version == corpus_version
end

verb source/retrieval_index_ready(model @ #string)
  if source/retrieval_corpus_ready(model) == false
    return false
  end

  for found in VectorIndexContains(#source/retrieval_index, ?embedding)
    return true
  end

  return false
end

verb source/retrieval_prewarm_complete()
  let model = source/retrieval_model()
  let corpus_version = source/retrieval_corpus_version()
  let indexed_version = one source/RetrievalCorpusIndexVersion(#source/retrieval_index, model, ?version)
  return indexed_version == corpus_version
end

verb source/retrieval_prewarm_status()
  if source/retrieval_prewarm_complete()
    return "complete"
  end

  let status = one source/RetrievalPrewarmStatus(source/retrieval_model(), ?status)
  if status == nothing
    return "pending"
  end

  return status
end

verb source/bump_retrieval_prewarm_revision(model @ #string)
  let revision = one source/RetrievalPrewarmRevision(model, ?revision)
  if revision == nothing
    revision = 0
  end

  revision = revision + 1
  retract source/RetrievalPrewarmRevision(model, _)
  assert source/RetrievalPrewarmRevision(model, revision)
  return revision
end

verb source/index_retrieval_subjects(actor, model @ #string)
  let indexed = 0
  for found in TextUnit(?subject)
    let subject = found[:subject]
    if source/RetrievalTextUnitModel(subject, model) && CanRetrieveSubject(actor, subject)
      let text = source/retrieval_text_unit_text(subject)
      ensure_subject_embedding(actor, #source/retrieval_index, subject, text, model)
      indexed = indexed + 1
    end
  end

  let corpus_version = source/retrieval_corpus_version()
  let indexed_version = one source/RetrievalCorpusIndexVersion(#source/retrieval_index, model, ?version)
  if indexed_version == corpus_version
    return indexed
  end

  for found in source/IndexedTextUnit(?subject, ?ordinal, ?kind, ?title, ?path, ?start_line, ?end_line, ?unit_model, ?text)
    if found[:unit_model] == model && source/CanBrowseRepository(actor, #source/repo_mica)
      ensure_subject_embedding(actor, #source/retrieval_index, found[:subject], found[:text], model)
      indexed = indexed + 1
    end
  end

  retract source/RetrievalCorpusIndexVersion(#source/retrieval_index, model, _)
  assert source/RetrievalCorpusIndexVersion(#source/retrieval_index, model, corpus_version)

  return indexed
end

verb source/prewarm_retrieval_index(actor)
  return source/index_retrieval_subjects(actor, source/retrieval_model())
end

verb source/run_retrieval_prewarm(actor)
  let model = source/retrieval_model()
  retract source/RetrievalPrewarmStatus(model, _)
  assert source/RetrievalPrewarmStatus(model, "running")
  source/bump_retrieval_prewarm_revision(model)

  let indexed = source/prewarm_retrieval_index(actor)

  retract source/RetrievalPrewarmCount(model, _)
  assert source/RetrievalPrewarmCount(model, indexed)
  retract source/RetrievalPrewarmStatus(model, _)
  assert source/RetrievalPrewarmStatus(model, "complete")
  source/bump_retrieval_prewarm_revision(model)
  return indexed
end

verb source/retrieve_context(actor, index, question_text @ #string, limit, model @ #string)
  let question = retrieval/question_value(actor, question_text, index, limit, model)
  assert Question(question)
  assert QuestionText(question, question_text)
  assert AskedBy(question, actor)

  let plan = retrieval/plan_value(question, index, limit, model)
  assert RetrievalPlan(plan)
  assert PlanForQuestion(plan, question)
  assert PlanKind(plan, "nearest_embedding")
  assert PlanModel(plan, model)

  let query_embedding = embed_text(model, question_text)
  let contexts = []
  for found in NearestEmbedding(index, query_embedding, limit, ?subject, ?score, ?snapshot_version)
    let subject = found[:subject]
    if source/can_retrieve_subject(actor, subject)
      let context = retrieval/context_value(plan, subject)
      assert RetrievedContext(context)
      assert ContextForPlan(context, plan)
      assert ContextSubject(context, subject)
      assert ContextScore(context, found[:score])
      assert ContextReason(context, "nearest_embedding")
      assert ContextSnapshotVersion(context, found[:snapshot_version])
      contexts = [@contexts, {:context -> context, :score -> found[:score], :subject -> subject, :snapshot_version -> found[:snapshot_version]}]
    end
  end

  return {:contexts -> contexts, :plan -> plan, :question -> question}
end

verb source/search_context(actor, question_text @ #string, limit, scope @ #string, model @ #string)
  let normalised_scope = source/normalise_retrieval_scope(scope)
  let question = frob(#retrieval/question, {:actor -> actor, :index -> #source/retrieval_index, :limit -> limit, :model -> model, :scope -> normalised_scope, :text -> question_text})
  assert Question(question)
  assert QuestionText(question, question_text)
  assert AskedBy(question, actor)

  let plan = frob(#retrieval/plan, {:index -> #source/retrieval_index, :limit -> limit, :model -> model, :question -> question, :scope -> normalised_scope})
  assert RetrievalPlan(plan)
  assert PlanForQuestion(plan, question)
  assert PlanKind(plan, "text_search")
  assert PlanModel(plan, model)

  let contexts = []
  let semantic_status = "vector_not_ready"
  for found in source/TextSearch(question_text, limit, normalised_scope, ?subject, ?score, ?path, ?start_line, ?end_line, ?kind, ?title, ?snippet)
    let subject = found[:subject]
    if source/can_retrieve_subject(actor, subject)
      let context = retrieval/context_value(plan, subject)
      assert RetrievedContext(context)
      assert ContextForPlan(context, plan)
      assert ContextSubject(context, subject)
      assert ContextScore(context, found[:score])
      assert ContextReason(context, "text_search")
      assert ContextSnapshotVersion(context, source/retrieval_corpus_version())
      assert source/RetrievalCitation(plan, subject)
      assert source/RetrievalCitationText(plan, subject, found[:snippet])
      assert source/RetrievalCitationLine(plan, subject, found[:start_line])
      contexts = [@contexts, {:context -> context, :score -> found[:score], :subject -> subject, :snapshot_version -> source/retrieval_corpus_version(), :snippet -> found[:snippet], :line -> found[:start_line]}]
    end
  end

  if source/retrieval_index_ready(model)
    semantic_status = "vector_ready"
    let query_embedding = embed_text(model, question_text)
    for found in NearestEmbedding(#source/retrieval_index, query_embedding, limit, ?subject, ?score, ?snapshot_version)
      let subject = found[:subject]
      if source/can_retrieve_subject(actor, subject)
        let context = retrieval/context_value(plan, subject)
        if ContextForPlan(context, plan)
          retract ContextReason(context, _)
          assert ContextReason(context, "text_search+nearest_embedding")
          retract ContextSnapshotVersion(context, _)
          assert ContextSnapshotVersion(context, found[:snapshot_version])
        else
          let snippet = source/retrieval_text_unit_text(subject)
          let line = source/retrieval_text_unit_line(subject)
          if snippet == nothing
            snippet = ""
          end
          if line == nothing
            line = 1
          end
          assert RetrievedContext(context)
          assert ContextForPlan(context, plan)
          assert ContextSubject(context, subject)
          assert ContextScore(context, found[:score])
          assert ContextReason(context, "nearest_embedding")
          assert ContextSnapshotVersion(context, found[:snapshot_version])
          assert source/RetrievalCitation(plan, subject)
          assert source/RetrievalCitationText(plan, subject, snippet)
          assert source/RetrievalCitationLine(plan, subject, line)
          contexts = [@contexts, {:context -> context, :score -> found[:score], :subject -> subject, :snapshot_version -> found[:snapshot_version], :snippet -> snippet, :line -> line}]
        end
        semantic_status = "vector_boosted"
      end
    end
  end

  return {:contexts -> contexts, :plan -> plan, :question -> question, :scope -> normalised_scope, :semantic_status -> semantic_status}
end

verb source/clear_retrieval_session(endpoint)
  retract source/SelectedRetrievalQuestion(endpoint, _)
  retract source/SelectedRetrievalPlan(endpoint, _)
  retract source/SelectedRetrievalModel(endpoint, _)
  retract source/SelectedRetrievalLimit(endpoint, _)
  retract source/SelectedRetrievalScope(endpoint, _)
  retract source/SelectedRetrievalSemanticStatus(endpoint, _)
  retract source/SelectedRetrievalStatus(endpoint, _)
  retract source/SelectedGeneratedAnswer(endpoint, _)
  return true
end

verb source/answer_context_line(plan, actor, subject)
  if source/can_retrieve_subject(actor, subject) == false
    return nothing
  end

  let path = source/retrieval_text_unit_path(subject)
  if path == nothing
    path = "unknown"
  end
  let line = one source/RetrievalCitationLine(plan, subject, ?line)
  if line == nothing
    line = source/retrieval_text_unit_line(subject)
  end
  let title = source/retrieval_text_unit_title(subject)
  if title == nothing
    title = path
  end
  let text = one source/RetrievalCitationText(plan, subject, ?text)
  if text == nothing
    text = source/retrieval_text_unit_text(subject)
  end
  if text == nothing
    text = ""
  end

  return string_concat("- ", path, ":", to_literal(line), " ", title, "\n", text)
end

verb source/answer_context_text(plan, actor)
  let lines = []
  for found in ContextForPlan(?context, plan)
    let subject = one ContextSubject(found[:context], ?subject)
    let line = source/answer_context_line(plan, actor, subject)
    if line != nothing
      lines = [@lines, line]
    end
  end

  return string_join(lines, "\n\n")
end

verb source/answer_prompt_text(question_text @ #string, context_text @ #string)
  return string_concat("You are answering a question about the Mica source workspace. Use only the cited context below. Cite source paths and line numbers. Do not include internal citation IDs in the answer. If the context is insufficient, say what is missing.\n\nQuestion:\n", question_text, "\n\nCited context:\n", context_text)
end

verb source/current_file_context_text(endpoint)
  let repository = source/current_repository()
  let revision = source/current_revision()
  let path = one source/SelectedPath(endpoint, ?path)
  if path == nothing
    path = source/current_file()
  end
  if path == nothing
    return "No source file is currently selected."
  end
  let line_count = one source/FileLineCount(repository, revision, path, ?line_count)
  if line_count == nothing
    return string_concat("Current file: ", path, "\nNo file text is available.")
  end
  let limit = source/agent_file_context_line_limit()
  if line_count < limit
    limit = line_count
  end
  let lines = []
  for row in source/FileLines(repository, revision, path, 1, limit, ?file_lines, ?hash)
    let line_number = 1
    for text in row[:file_lines]
      lines = [@lines, string_concat(to_literal(line_number), ": ", text)]
      line_number = line_number + 1
    end
    break
  end
  let truncation = ""
  if line_count > limit
    truncation = string_concat("\n\nFile context truncated at ", to_literal(limit), " of ", to_literal(line_count), " lines.")
  end
  return string_concat("Current file: ", path, "\nFile lines 1-", to_literal(limit), " of ", to_literal(line_count), ":\n", string_join(lines, "\n"), truncation)
end

verb source/agent_history_text(endpoint)
  let lines = []
  for found in source/AgentTurnEndpoint(?turn, endpoint)
    let turn = found[:turn]
    let role = one source/AgentTurnRole(turn, ?role)
    let text = one source/AgentTurnText(turn, ?text)
    if role == nothing
      role = "assistant"
    end
    if text == nothing
      text = ""
    end
    lines = [@lines, string_concat(role, ": ", text)]
  end
  if lines == []
    return "No previous turns."
  end
  return string_join(lines, "\n\n")
end

verb source/next_agent_turn_ordinal(endpoint)
  let ordinal = 1
  for found in source/AgentTurnEndpoint(?turn, endpoint)
    ordinal = ordinal + 1
  end
  return ordinal
end

verb source/agent_tool_request_value(turn, ordinal)
  return frob(#source/agent_tool_request, {:turn -> turn, :ordinal -> ordinal})
end

verb source/record_agent_tool_request(turn, ordinal, tool @ #string, args, status @ #string)
  let request = source/agent_tool_request_value(turn, ordinal)
  retract source/AgentToolRequest(request, _, _, _, _)
  retract source/AgentToolCallForTurn(request, _)
  assert source/AgentToolRequest(request, ordinal, tool, args, status)
  assert source/AgentToolCallForTurn(request, turn)
  return request
end

verb source/record_agent_tool_result(request, result, status @ #string, error @ #string)
  let ordinal = nothing
  let tool = nothing
  let args = nothing
  for found in source/AgentToolRequest(request, ?request_ordinal, ?request_tool, ?request_args, ?request_status)
    ordinal = found[:request_ordinal]
    tool = found[:request_tool]
    args = found[:request_args]
    break
  end

  retract source/AgentToolResult(request, _, _, _)
  assert source/AgentToolResult(request, result, status, error)
  if ordinal != nothing
    retract source/AgentToolRequest(request, _, _, _, _)
    assert source/AgentToolRequest(request, ordinal, tool, args, status)
  end
  return request
end

verb source/record_agent_tool_transcript_text(request, text @ #string)
  retract source/AgentToolTranscriptText(request, _)
  assert source/AgentToolTranscriptText(request, text)
  return text
end

verb source/agent_turn_endpoint(turn)
  return one source/AgentTurnEndpoint(turn, ?endpoint)
end

verb source/update_agent_turn_progress(turn, text @ #string)
  retract source/AgentTurnText(turn, _)
  retract source/AgentTurnStatus(turn, _)
  assert source/AgentTurnText(turn, text)
  assert source/AgentTurnStatus(turn, "working")
  let endpoint = source/agent_turn_endpoint(turn)
  if endpoint != nothing
    source/bump_revision(endpoint)
  end
  return text
end

verb source/agent_tool_call_count(tool_calls)
  let count = 0
  for call in tool_calls
    count = count + 1
  end
  return count
end

verb source/agent_tool_call_signature(call @ #map)
  let name = source/openai_tool_call_name(call)
  let args = source/openai_tool_call_args(call)
  return string_concat(to_literal(name), " ", to_literal(args))
end

verb source/agent_focus_text(endpoint)
  let path = one source/SelectedPath(endpoint, ?path)
  if path == nothing
    path = source/current_file()
  end
  let line = one source/SelectedLine(endpoint, ?line)
  if path == nothing
    return "No source file is currently selected."
  end
  if line == nothing
    line = 1
  end
  return string_concat("Current source focus: ", path, ":", to_literal(line))
end

verb source/agent_workspace_schema_text()
  let files = "- Files: source/Repository(repository), source/RepositoryRoot(repository, root), source/SourceFile(file), source/FileRevision(file, revision), source/FilePath(file, path), source/FileTitle(file, title), source/FileLanguage(file, language), source/FileLines(repository, revision, path, start, line_count, lines, hash), source/FileLineCount(repository, revision, path, count).\n"
  let spans = "- Spans and symbols: source/SourceSpan(span), source/SpanFile(span, path), source/SpanLabel(span, label), source/SpanStartLine(span, line), source/SpanEndLine(span, line), source/DefinitionAt(path, line, symbol), source/ReferencesOf(symbol, reference), source/SyntaxOutline(path, outline).\n"
  let retrieval = "- Retrieval: source/RetrievalTextUnitFile(subject, path), source/RetrievalTextUnitSpan(subject, start, end), source/RetrievalTextUnitTitle(subject, title), source/RetrievalCitationText(plan, subject, text), ContextForPlan(context, plan), ContextSubject(context, subject), ContextScore(context, score).\n"
  let session = "- Session focus: source/SelectedPath(endpoint, path), source/SelectedLine(endpoint, line), source/SelectedRevision(endpoint, revision), source/SelectedAgentStatus(endpoint, status).\n"
  let query_shape = "- Mica query shape: use for row in Relation(?x, value, ?y) to scan relation facts, one Relation(...) for one result, row[:x] for query bindings, lists and maps for structured output, and small bounded result sets.\n"
  let line_query = "- Example line-window query: for row in source/FileLines(#source/repo_mica, source/current_revision(), path, 1, 120, ?lines, ?hash) return row[:lines].\n"
  let symbol_query = "- Example symbol lead query: for row in source/ReferencesOf(?symbol, ?reference) return row.\n"
  let grounding = "Only rely on query recipes when a mica_query tool result is present. Do not claim to have inspected facts, files, or line ranges that are not in the current context, retrieved context, or a recorded tool result."
  return string_concat("Source workspace schema and query recipes:\n", files, spans, retrieval, session, query_shape, line_query, symbol_query, grounding)
end

verb source/agent_prompt_text(user_text @ #string, focus_text @ #string, context_text @ #string)
  let schema_text = source/agent_workspace_schema_text()
  return string_concat("You are talking with a developer about the Mica source workspace. Use the current file context first. Use retrieved context only as supporting evidence. Be concrete about files, symbols, and uncertainty. Cite paths and line numbers, not internal citation IDs. If the current file context is truncated and the answer depends on unavailable lines, call source_file_window for the needed line range before answering. If evidence is still missing, say what extra file lines or source facts are needed. Do not claim you inspected unavailable context.\n\n", schema_text, "\n\nUser request:\n", user_text, "\n\n", focus_text, "\n\nContext:\n", context_text)
end

verb source/agent_tool_options()
  let query_parameters = {:type -> "object", :properties -> {:query -> {:type -> "string", :description -> "A read-only Mica query to run as the current source viewer endpoint."}}, :required -> ["query"], :additionalProperties -> false}
  let query_function = {:name -> "mica_query", :description -> "Run a read-only Mica query over authorized source workspace facts. The query cannot mutate state, spawn tasks, invoke methods, or call host effects.", :parameters -> query_parameters}
  let query_tool = {:type -> "function", :function -> query_function}
  let search_properties = {:query -> {:type -> "string", :description -> "Source search query text."}, :scope -> {:type -> "string", :description -> "Optional search scope: all, code, docs, tests, benches, or sketches."}, :limit -> {:type -> "integer", :description -> "Maximum results to return. Defaults to the source retrieval limit and is capped at 12."}}
  let search_parameters = {:type -> "object", :properties -> search_properties, :required -> ["query"], :additionalProperties -> false}
  let search_function = {:name -> "source_search", :description -> "Search the indexed source corpus and return bounded path, line, title, kind, score, reason, and snippet leads.", :parameters -> search_parameters}
  let search_tool = {:type -> "function", :function -> search_function}
  let symbol_properties = {:path -> {:type -> "string", :description -> "Optional repository-relative file path for definition lookup."}, :byte_offset -> {:type -> "integer", :description -> "Optional byte offset in path for definition lookup."}, :query -> {:type -> "string", :description -> "Optional symbol search query. Used when path and byte_offset are not supplied."}, :reference_limit -> {:type -> "integer", :description -> "Maximum references to return. Defaults to 12 and is capped at 30."}}
  let symbol_parameters = {:type -> "object", :properties -> symbol_properties, :additionalProperties -> false}
  let symbol_function = {:name -> "source_symbol_context", :description -> "Return definition metadata and bounded reference leads for a source symbol, using explicit path+byte_offset, symbol search query, or the current selected symbol.", :parameters -> symbol_parameters}
  let symbol_tool = {:type -> "function", :function -> symbol_function}
  let references_properties = {:symbol -> {:type -> "string", :description -> "Optional provider symbol id. Defaults to the current selected symbol."}, :path -> {:type -> "string", :description -> "Optional repository-relative file path for resolving a symbol at byte_offset."}, :byte_offset -> {:type -> "integer", :description -> "Optional byte offset in path for resolving a symbol."}, :query -> {:type -> "string", :description -> "Optional symbol search query used when symbol or path+byte_offset are not supplied."}, :limit -> {:type -> "integer", :description -> "Maximum references to return. Defaults to 30 and is capped at 60."}}
  let references_parameters = {:type -> "object", :properties -> references_properties, :additionalProperties -> false}
  let references_function = {:name -> "source_find_references", :description -> "Return bounded reference locations and line snippets for a source symbol without changing UI state.", :parameters -> references_parameters}
  let references_tool = {:type -> "function", :function -> references_function}
  let note_tool = source/agent_proposal_tool("source_create_pending_note", "Create a pending source-agent note for human review. This records reviewable proposal state only; it does not apply durable note or workspace mutations.", "Detailed note text for review.")
  let finding_tool = source/agent_proposal_tool("source_create_pending_finding", "Create a pending source-agent finding for human review. This records reviewable proposal state only; it does not apply durable finding or workspace mutations.", "Detailed finding text for review.")
  let patch_tool = source/agent_proposal_tool("source_propose_patch", "Create a pending source-agent patch proposal for human review. This records reviewable proposal state only; it does not apply code or workspace mutations.", "Detailed patch proposal for review. Include a unified diff if one is available, otherwise describe the exact intended edit.")
  let action_tool = source/agent_proposal_tool("source_propose_action", "Create a pending source-agent action proposal for human review. This records reviewable proposal state only; it does not execute the action or mutate workspace facts.", "Detailed action proposal for review.")
  let window_properties = {:path -> {:type -> "string", :description -> "Repository-relative path. Defaults to the current selected file."}, :start_line -> {:type -> "integer", :description -> "One-based starting line. Defaults to 1."}, :line_count -> {:type -> "integer", :description -> "Number of lines to return. Capped at 200."}}
  let window_parameters = {:type -> "object", :properties -> window_properties, :additionalProperties -> false}
  let window_function = {:name -> "source_file_window", :description -> "Read a bounded line window from a source file without writing a Mica query. Use this when current file context is truncated or a specific line range is needed.", :parameters -> window_parameters}
  let window_tool = {:type -> "function", :function -> window_function}
  return {:temperature -> 0.2, :tools -> [search_tool, symbol_tool, references_tool, note_tool, finding_tool, patch_tool, action_tool, window_tool, query_tool], :tool_choice -> "auto"}
end

verb source/agent_tool_call_limit()
  let limit = one source/RuntimeConfig(#source/config_agent_tool_call_limit, ?limit)
  if limit == nothing
    return 24
  end
  return limit
end

verb source/agent_proposal_tool(name @ #string, description @ #string, body_description @ #string)
  let properties = {:title -> {:type -> "string", :description -> "Short human-readable proposal title."}, :body -> {:type -> "string", :description -> body_description}, :target_path -> {:type -> "string", :description -> "Optional source path this proposal concerns."}, :start_line -> {:type -> "integer", :description -> "Optional one-based start line for the target."}, :end_line -> {:type -> "integer", :description -> "Optional one-based end line for the target."}}
  let parameters = {:type -> "object", :properties -> properties, :required -> ["title", "body"], :additionalProperties -> false}
  let function = {:name -> name, :description -> description, :parameters -> parameters}
  return {:type -> "function", :function -> function}
end

verb source/openai_first_message(response @ #map)
  let choices = response[:choices]
  if choices == nothing || choices == []
    return nothing
  end
  let first = choices[0]
  if first == nothing
    return nothing
  end
  return first[:message]
end

verb source/openai_tool_calls(response @ #map)
  let message = source/openai_first_message(response)
  if message == nothing
    return []
  end
  let tool_calls = message[:tool_calls]
  if tool_calls == nothing
    return []
  end
  return tool_calls
end

verb source/openai_tool_call_id(call @ #map, ordinal)
  let call_id = call[:id]
  if call_id == nothing
    call_id = string_concat("mica_query_", to_literal(ordinal))
  end
  return call_id
end

verb source/openai_tool_call_name(call @ #map)
  let function = call[:function]
  if function == nothing
    return nothing
  end
  return function[:name]
end

verb source/openai_tool_call_args(call @ #map)
  let function = call[:function]
  if function == nothing
    return {}
  end
  let args = function[:arguments]
  if args == nothing
    return {}
  end
  return recover json_decode(args)
  catch err => args
  end
end

verb source/openai_tool_message(call_id @ #string, result @ #map)
  return {:role -> "tool", :tool_call_id -> call_id, :content -> json_encode(result)}
end

verb source/tool_error_result(status @ #string, message @ #string)
  return {:status -> status, :rendered -> message, :rendered_truncated -> false, :value -> nothing, :error -> nothing, :diagnostics -> [message]}
end

verb source/source_file_window_result(args @ #map)
  let path = args[:path]
  if path == nothing || path == ""
    path = source/current_file()
  end
  if path == nothing
    return source/tool_error_result("error", "source_file_window has no current file")
  end
  let start_line = args[:start_line]
  if start_line == nothing || start_line < 1
    start_line = 1
  end
  let requested_count = args[:line_count]
  if requested_count == nothing || requested_count < 1
    requested_count = 120
  end
  if requested_count > 200
    requested_count = 200
  end
  let repository = source/current_repository()
  let revision = source/current_revision()
  let total_lines = one source/FileLineCount(repository, revision, path, ?line_count)
  if total_lines == nothing
    return source/tool_error_result("error", string_concat("source_file_window could not read file: ", path))
  end
  if start_line > total_lines
    start_line = total_lines
  end
  let window_start = start_line
  let lines = []
  let rendered_lines = []
  let end_line = start_line - 1
  for row in source/FileLines(repository, revision, path, start_line, requested_count, ?file_lines, ?hash)
    let line_offset = 0
    for text in row[:file_lines]
      let line_number = window_start + line_offset
      lines = [@lines, {:line -> line_number, :text -> text}]
      rendered_lines = [@rendered_lines, string_concat(to_literal(line_number), ": ", text)]
      end_line = line_number
      line_offset = line_offset + 1
    end
    break
  end
  let rendered = string_concat(path, ":", to_literal(window_start), "-", to_literal(end_line), "\n", string_join(rendered_lines, "\n"))
  let value = {:path -> path, :start_line -> window_start, :end_line -> end_line, :line_count -> total_lines, :lines -> lines}
  return {:status -> "complete", :rendered -> rendered, :rendered_truncated -> false, :value -> value, :error -> nothing, :diagnostics -> []}
end

verb source/source_search_result(actor, args @ #map)
  let query = args[:query]
  if query == nothing || query == ""
    return source/tool_error_result("rejected", "source_search missing query")
  end
  let scope = args[:scope]
  if scope == nothing || scope == ""
    scope = source/default_retrieval_scope()
  end
  scope = source/normalise_retrieval_scope(scope)
  let limit = args[:limit]
  if limit == nothing || limit < 1
    limit = source/retrieval_limit()
  end
  if limit > 12
    limit = 12
  end

  let model = source/retrieval_model()
  let retrieval = source/search_context(actor, query, limit, scope, model)
  let plan = retrieval[:plan]
  let semantic_status = retrieval[:semantic_status]
  let results = []
  let rendered_lines = []
  let count = 0
  for item in retrieval[:contexts]
    if count >= limit
      break
    end
    let context = item[:context]
    let subject = item[:subject]
    let path = source/retrieval_text_unit_path(subject)
    if path == nothing
      path = "unknown"
    end
    let line = item[:line]
    if line == nothing
      line = source/retrieval_text_unit_line(subject)
    end
    if line == nothing
      line = 1
    end
    let title = source/retrieval_text_unit_title(subject)
    if title == nothing
      title = path
    end
    let kind = source/retrieval_text_unit_kind(subject)
    if kind == nothing
      kind = "context"
    end
    let reason = one ContextReason(context, ?reason)
    if reason == nothing
      reason = "retrieval"
    end
    let snippet = item[:snippet]
    if snippet == nothing
      snippet = source/retrieval_text_unit_text(subject)
    end
    if snippet == nothing
      snippet = ""
    end
    let score = item[:score]
    if score == nothing
      score = 0
    end
    results = [@results, {:path -> path, :line -> line, :title -> title, :kind -> kind, :score -> score, :reason -> reason, :snippet -> snippet}]
    rendered_lines = [@rendered_lines, string_concat("- ", path, ":", to_literal(line), " ", title, " / ", kind, " / ", reason, " / ", to_literal(score), "\n", snippet)]
    count = count + 1
  end

  let rendered = string_join(rendered_lines, "\n\n")
  if rendered == ""
    rendered = "source_search returned no results"
  end
  let value = {:query -> query, :scope -> scope, :limit -> limit, :model -> model, :semantic_status -> semantic_status, :plan -> to_literal(plan), :results -> results}
  return {:status -> "complete", :rendered -> rendered, :rendered_truncated -> false, :value -> value, :error -> nothing, :diagnostics -> []}
end

verb source/symbol_line_text(repository, revision, path @ #string, line)
  if line == nothing || line < 1
    return ""
  end
  for row in source/FileLines(repository, revision, path, line, 1, ?lines, ?hash)
    if row[:lines] != nothing && row[:lines] != []
      return row[:lines][0]
    end
    break
  end

  return ""
end

verb source/symbol_reference_results(repository, revision, symbol, limit)
  let references = []
  let count = 0
  for reference in source/ReferencesOf(repository, revision, symbol, ?path, ?start_line, ?end_line, ?start_byte, ?end_byte, ?provider, ?name)
    if count >= limit
      break
    end
    let snippet = source/symbol_line_text(repository, revision, reference[:path], reference[:start_line])
    references = [@references, {:path -> reference[:path], :start_line -> reference[:start_line], :end_line -> reference[:end_line], :start_byte -> reference[:start_byte], :end_byte -> reference[:end_byte], :provider -> reference[:provider], :name -> reference[:name], :snippet -> snippet}]
    count = count + 1
  end
  return references
end

verb source/resolve_source_symbol(args @ #map)
  let repository = source/current_repository()
  let revision = source/current_revision()
  let symbol = args[:symbol]
  if symbol != nothing && symbol != ""
    return {:symbol -> symbol, :name -> args[:name], :kind -> args[:kind], :path -> args[:path], :start_line -> args[:start_line], :end_line -> args[:end_line], :start_byte -> args[:start_byte], :end_byte -> args[:end_byte], :provider -> args[:provider], :source -> "symbol"}
  end

  let path = args[:path]
  let byte_offset = args[:byte_offset]
  if path != nothing && path != "" && byte_offset != nothing && byte_offset >= 0
    for def in source/DefinitionAt(repository, revision, path, byte_offset, ?found_symbol, ?name, ?kind, ?target_path, ?start_line, ?end_line, ?start_byte, ?end_byte, ?provider)
      return {:symbol -> def[:found_symbol], :name -> def[:name], :kind -> def[:kind], :path -> def[:target_path], :start_line -> def[:start_line], :end_line -> def[:end_line], :start_byte -> def[:start_byte], :end_byte -> def[:end_byte], :provider -> def[:provider], :source -> "definition_at"}
    end
  end

  let query = args[:query]
  if query != nothing && query != ""
    for found in source/SymbolSearch(repository, revision, query, 1, ?found_symbol, ?name, ?kind, ?found_path, ?start_line, ?end_line, ?provider)
      return {:symbol -> found[:found_symbol], :name -> found[:name], :kind -> found[:kind], :path -> found[:found_path], :start_line -> found[:start_line], :end_line -> found[:end_line], :start_byte -> nothing, :end_byte -> nothing, :provider -> found[:provider], :source -> "symbol_search"}
    end
  end

  let selected_symbol = one source/SelectedSymbol(endpoint(), ?symbol)
  if selected_symbol != nothing
    let name = one source/SelectedSymbolName(endpoint(), ?name)
    let kind = one source/SelectedSymbolKind(endpoint(), ?kind)
    let selected_path = one source/SelectedDefinitionPath(endpoint(), ?path)
    let start_line = one source/SelectedDefinitionStartLine(endpoint(), ?line)
    let end_line = one source/SelectedDefinitionEndLine(endpoint(), ?line)
    let start_byte = one source/SelectedDefinitionStartByte(endpoint(), ?byte)
    let end_byte = one source/SelectedDefinitionEndByte(endpoint(), ?byte)
    let provider = one source/SelectedSymbolProvider(endpoint(), ?provider)
    return {:symbol -> selected_symbol, :name -> name, :kind -> kind, :path -> selected_path, :start_line -> start_line, :end_line -> end_line, :start_byte -> start_byte, :end_byte -> end_byte, :provider -> provider, :source -> "selected_symbol"}
  end

  return nothing
end

verb source/source_symbol_context_result(args @ #map)
  let repository = source/current_repository()
  let revision = source/current_revision()
  let reference_limit = args[:reference_limit]
  if reference_limit == nothing || reference_limit < 1
    reference_limit = 12
  end
  if reference_limit > 30
    reference_limit = 30
  end

  let selected = source/resolve_source_symbol(args)
  if selected == nothing
    return source/tool_error_result("error", "source_symbol_context could not resolve a symbol")
  end

  let definition_path = selected[:path]
  let definition_line = selected[:start_line]
  if definition_path == nothing
    definition_path = "unknown"
  end
  if definition_line == nothing
    definition_line = 1
  end
  let definition_end_line = selected[:end_line]
  if definition_end_line == nothing
    definition_end_line = definition_line
  end
  let snippet = ""
  if definition_path != "unknown"
    snippet = recover source/symbol_line_text(repository, revision, definition_path, definition_line)
    catch err => ""
    end
  end
  let references = recover source/symbol_reference_results(repository, revision, selected[:symbol], reference_limit)
  catch err => []
  end
  let reference_count = 0
  let rendered_refs = []
  for reference in references
    reference_count = reference_count + 1
    let reference_name = reference[:name]
    if reference_name == nothing
      reference_name = "reference"
    end
    let reference_provider = reference[:provider]
    if reference_provider == nothing
      reference_provider = "unknown"
    end
    rendered_refs = [@rendered_refs, string_concat("- ", reference[:path], ":", to_literal(reference[:start_line]), " ", reference_name, " / ", reference_provider, "\n", reference[:snippet])]
  end

  let name = selected[:name]
  if name == nothing
    name = to_literal(selected[:symbol])
  end
  let kind = selected[:kind]
  if kind == nothing
    kind = "symbol"
  end
  let provider = selected[:provider]
  if provider == nothing
    provider = "unknown"
  end
  let rendered = string_concat(name, " / ", kind, "\ndefinition: ", definition_path, ":", to_literal(definition_line), "-", to_literal(definition_end_line), " / ", provider, "\n", snippet)
  if rendered_refs != []
    rendered = string_concat(rendered, "\n\nreferences:\n", string_join(rendered_refs, "\n"))
  end
  let value = {:symbol -> to_literal(selected[:symbol]), :name -> name, :kind -> kind, :definition -> {:path -> definition_path, :start_line -> definition_line, :end_line -> definition_end_line, :start_byte -> selected[:start_byte], :end_byte -> selected[:end_byte], :provider -> provider, :snippet -> snippet}, :references -> references, :reference_count -> reference_count, :reference_limit -> reference_limit, :source -> selected[:source]}
  return {:status -> "complete", :rendered -> rendered, :rendered_truncated -> false, :value -> value, :error -> nothing, :diagnostics -> []}
end

verb source/source_find_references_result(args @ #map)
  let repository = source/current_repository()
  let revision = source/current_revision()
  let limit = args[:limit]
  if limit == nothing || limit < 1
    limit = 30
  end
  if limit > 60
    limit = 60
  end

  let selected = source/resolve_source_symbol(args)
  if selected == nothing
    return source/tool_error_result("error", "source_find_references could not resolve a symbol")
  end

  let references = recover source/symbol_reference_results(repository, revision, selected[:symbol], limit)
  catch err => []
  end
  let rendered_lines = []
  let count = 0
  for reference in references
    count = count + 1
    let name = reference[:name]
    if name == nothing
      name = "reference"
    end
    let provider = reference[:provider]
    if provider == nothing
      provider = "unknown"
    end
    rendered_lines = [@rendered_lines, string_concat("- ", reference[:path], ":", to_literal(reference[:start_line]), " ", name, " / ", provider, "\n", reference[:snippet])]
  end

  let rendered = string_join(rendered_lines, "\n\n")
  if rendered == ""
    rendered = "source_find_references returned no references"
  end
  let value = {:symbol -> to_literal(selected[:symbol]), :name -> selected[:name], :kind -> selected[:kind], :limit -> limit, :count -> count, :source -> selected[:source], :references -> references}
  return {:status -> "complete", :rendered -> rendered, :rendered_truncated -> false, :value -> value, :error -> nothing, :diagnostics -> []}
end

verb source/agent_proposal_value(turn, ordinal)
  return frob(#source/agent_proposal, {:turn -> turn, :ordinal -> ordinal})
end

verb source/create_agent_proposal(turn, ordinal, kind @ #string, args @ #map)
  let title = args[:title]
  let body = args[:body]
  if title == nothing || title == ""
    return source/tool_error_result("rejected", string_concat("source ", kind, " proposal missing title"))
  end
  if body == nothing || body == ""
    return source/tool_error_result("rejected", string_concat("source ", kind, " proposal missing body"))
  end
  let proposal = source/agent_proposal_value(turn, ordinal)
  retract source/AgentProposal(proposal)
  retract source/AgentProposalTurn(proposal, _)
  retract source/AgentProposalOrdinal(proposal, _)
  retract source/AgentProposalKind(proposal, _)
  retract source/AgentProposalTitle(proposal, _)
  retract source/AgentProposalBody(proposal, _)
  retract source/AgentProposalPayload(proposal, _)
  retract source/AgentProposalStatus(proposal, _)
  assert source/AgentProposal(proposal)
  assert source/AgentProposalTurn(proposal, turn)
  assert source/AgentProposalOrdinal(proposal, ordinal)
  assert source/AgentProposalKind(proposal, kind)
  assert source/AgentProposalTitle(proposal, title)
  assert source/AgentProposalBody(proposal, body)
  assert source/AgentProposalPayload(proposal, args)
  assert source/AgentProposalStatus(proposal, "pending")
  let rendered = string_concat("pending ", kind, " proposal: ", title, "\n", body)
  let value = {:proposal -> to_literal(proposal), :kind -> kind, :title -> title, :body -> body, :status -> "pending", :payload -> args}
  return {:status -> "complete", :rendered -> rendered, :rendered_truncated -> false, :value -> value, :error -> nothing, :diagnostics -> []}
end

verb source/accept_agent_proposal(proposal)
  if source/AgentProposal(proposal) == false
    return false
  end
  retract source/AgentProposalStatus(proposal, _)
  assert source/AgentProposalStatus(proposal, "accepted")
  return true
end

verb source/reject_agent_proposal(proposal)
  if source/AgentProposal(proposal) == false
    return false
  end
  retract source/AgentProposalStatus(proposal, _)
  assert source/AgentProposalStatus(proposal, "rejected")
  return true
end

verb source/correct_agent_proposal(proposal, body @ #string)
  if source/AgentProposal(proposal) == false
    return false
  end
  retract source/AgentProposalBody(proposal, _)
  assert source/AgentProposalBody(proposal, body)
  retract source/AgentProposalStatus(proposal, _)
  assert source/AgentProposalStatus(proposal, "corrected")
  return true
end

verb source/start_agent_tool_request(turn, ordinal, tool @ #string, args)
  log(:info, string_concat("source agent tool started ordinal=", to_literal(ordinal), " tool=", tool))
  source/update_agent_turn_progress(turn, string_concat("Running tool ", to_literal(ordinal), "/", to_literal(source/agent_tool_call_limit()), ": ", tool))
  let request = source/record_agent_tool_request(turn, ordinal, tool, args, "running")
  source/record_agent_tool_transcript_text(request, string_concat(tool, " running\narguments: ", to_literal(args)))
  return request
end

verb source/finish_agent_tool_request(request, result @ #map, call_id @ #string)
  let status = result[:status]
  if status == nothing
    status = "error"
  end
  let error = ""
  if status != "complete"
    error = result[:rendered]
  end
  source/record_agent_tool_result(request, result, status, error)
  source/record_agent_tool_transcript_text(request, string_concat(status, "\n", result[:rendered]))
  let tool = "unknown"
  let ordinal = nothing
  for found in source/AgentToolRequest(request, ?request_ordinal, ?request_tool, ?request_args, ?request_status)
    ordinal = found[:request_ordinal]
    tool = found[:request_tool]
    break
  end
  log(:info, string_concat("source agent tool finished ordinal=", to_literal(ordinal), " tool=", tool, " status=", status))
  let turn = one source/AgentToolCallForTurn(request, ?turn)
  if turn != nothing
    let endpoint = source/agent_turn_endpoint(turn)
    if endpoint != nothing
      source/bump_revision(endpoint)
    end
  end
  return source/openai_tool_message(call_id, result)
end

verb source/record_agent_tool_response(turn, ordinal, tool @ #string, args @ #map, result @ #map, call_id @ #string)
  let request = source/start_agent_tool_request(turn, ordinal, tool, args)
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_source_file_window_tool(turn, ordinal, call @ #map)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, "source_file_window", args)
  let result = recover source/source_file_window_result(args)
  catch err => source/tool_error_result("error", to_literal(err))
  end
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_source_search_tool(turn, ordinal, call @ #map, actor)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, "source_search", args)
  let result = recover source/source_search_result(actor, args)
  catch err => source/tool_error_result("error", to_literal(err))
  end
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_source_symbol_context_tool(turn, ordinal, call @ #map)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, "source_symbol_context", args)
  let result = recover source/source_symbol_context_result(args)
  catch err => source/tool_error_result("error", to_literal(err))
  end
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_source_find_references_tool(turn, ordinal, call @ #map)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, "source_find_references", args)
  let result = recover source/source_find_references_result(args)
  catch err => source/tool_error_result("error", to_literal(err))
  end
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_proposal_tool(turn, ordinal, call @ #map, tool @ #string, kind @ #string)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, tool, args)
  let result = recover source/create_agent_proposal(turn, ordinal, kind, args)
  catch err => source/tool_error_result("error", to_literal(err))
  end
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_mica_query_tool(turn, ordinal, call @ #map)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, "mica_query", args)
  let query = args[:query]
  if query == nothing
    let result = source/tool_error_result("rejected", "mica_query missing query")
    return source/finish_agent_tool_request(request, result, call_id)
  end
  let result = mica_query(query, {:max_output_chars -> 4000, :instruction_budget -> 50000, :max_call_depth -> 16})
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/run_agent_tool(turn, ordinal, call @ #map, actor)
  let call_id = source/openai_tool_call_id(call, ordinal)
  let name = source/openai_tool_call_name(call)
  if name == "mica_query"
    return source/run_agent_mica_query_tool(turn, ordinal, call)
  end
  if name == "source_file_window"
    return source/run_agent_source_file_window_tool(turn, ordinal, call)
  end
  if name == "source_search"
    return source/run_agent_source_search_tool(turn, ordinal, call, actor)
  end
  if name == "source_symbol_context"
    return source/run_agent_source_symbol_context_tool(turn, ordinal, call)
  end
  if name == "source_find_references"
    return source/run_agent_source_find_references_tool(turn, ordinal, call)
  end
  if name == "source_create_pending_note"
    return source/run_agent_proposal_tool(turn, ordinal, call, "source_create_pending_note", "note")
  end
  if name == "source_create_pending_finding"
    return source/run_agent_proposal_tool(turn, ordinal, call, "source_create_pending_finding", "finding")
  end
  if name == "source_propose_patch"
    return source/run_agent_proposal_tool(turn, ordinal, call, "source_propose_patch", "patch")
  end
  if name == "source_propose_action"
    return source/run_agent_proposal_tool(turn, ordinal, call, "source_propose_action", "action")
  end
  let args = source/openai_tool_call_args(call)
  let request = source/start_agent_tool_request(turn, ordinal, to_literal(name), args)
  let result = source/tool_error_result("rejected", string_concat("unsupported tool: ", to_literal(name)))
  return source/finish_agent_tool_request(request, result, call_id)
end

verb source/source_index_available()
  for found in source/SourceIndex(?index)
    return true
  end
  return false
end

verb source/record_agent_turn_citations(turn, plan, actor)
  if plan == nothing
    return 0
  end

  let count = 0
  for found in ContextForPlan(?context, plan)
    let subject = one ContextSubject(found[:context], ?subject)
    if source/can_retrieve_subject(actor, subject)
      assert source/AgentTurnCitation(turn, subject)
      let text = one source/RetrievalCitationText(plan, subject, ?text)
      if text == nothing
        text = source/retrieval_text_unit_text(subject)
      end
      if text != nothing
        assert source/AgentTurnCitationText(turn, subject, text)
      end
      count = count + 1
    end
  end
  return count
end

verb source/record_agent_user_turn(endpoint, user_text @ #string)
  if user_text == ""
    return nothing
  end

  let user_ordinal = source/next_agent_turn_ordinal(endpoint)
  let user_turn = frob(#source/agent_turn, {:endpoint -> endpoint, :ordinal -> user_ordinal, :role -> "user", :text -> user_text})
  assert source/AgentTurn(user_turn)
  assert source/AgentTurnEndpoint(user_turn, endpoint)
  assert source/AgentTurnOrdinal(user_turn, user_ordinal)
  assert source/AgentTurnRole(user_turn, "user")
  assert source/AgentTurnText(user_turn, user_text)
  assert source/AgentTurnStatus(user_turn, "complete")
  return user_turn
end

verb source/complete_agent_prompt(endpoint, actor, user_text @ #string)
  log(:info, "source agent prompt completion started")
  let history_text = source/agent_history_text(endpoint)

  let current_context = source/current_file_context_text(endpoint)
  let plan = nothing
  let retrieved_context = ""
  if source/source_index_available()
    let retrieval = source/search_context(actor, user_text, source/retrieval_limit(), "all", source/retrieval_model())
    plan = retrieval[:plan]
    retrieved_context = source/answer_context_text(plan, actor)
  end
  let context_text = string_concat("Previous turns:\n", history_text, "\n\nCurrent file context:\n", current_context, "\n\nRetrieved context:\n", retrieved_context)
  let focus_text = source/agent_focus_text(endpoint)
  let requested_model = source/generation_model()
  let provider = source/generation_provider()
  let prompt = source/agent_prompt_text(user_text, focus_text, context_text)
  let assistant_ordinal = source/next_agent_turn_ordinal(endpoint)
  let assistant_turn = frob(#source/agent_turn, {:endpoint -> endpoint, :ordinal -> assistant_ordinal, :role -> "assistant", :text -> ""})
  assert source/AgentTurn(assistant_turn)
  assert source/AgentTurnEndpoint(assistant_turn, endpoint)
  assert source/AgentTurnOrdinal(assistant_turn, assistant_ordinal)
  assert source/AgentTurnRole(assistant_turn, "assistant")
  assert source/AgentTurnText(assistant_turn, "")
  assert source/AgentTurnStatus(assistant_turn, "working")
  if plan != nothing
    assert source/AgentTurnPlan(assistant_turn, plan)
  end
  assert source/AgentTurnPromptText(assistant_turn, prompt)
  assert source/AgentTurnContextText(assistant_turn, context_text)
  assert source/AgentTurnProvider(assistant_turn, provider)
  assert source/AgentTurnModel(assistant_turn, requested_model)
  source/update_agent_turn_progress(assistant_turn, string_concat("Preparing model request for ", requested_model, "."))

  let messages = [openai/system_message("Talk about the Mica source workspace using cited source evidence."), openai/user_message(prompt)]
  let options = source/agent_tool_options()
  let response = nothing
  let tool_count = 0
  let tool_limit = source/agent_tool_call_limit()
  let guard_reason = ""
  let last_tool_signature = ""
  let repeated_tool_count = 0
  let consecutive_tool_failures = 0
  let model_round = 1
  while guard_reason == "" && tool_count < tool_limit
    log(:info, string_concat("source agent model request started round=", to_literal(model_round), " model=", requested_model, " tools_used=", to_literal(tool_count), "/", to_literal(tool_limit), " prompt_chars=", to_literal(string_len(prompt))))
    source/update_agent_turn_progress(assistant_turn, string_concat("Calling model round ", to_literal(model_round), " with ", to_literal(tool_count), "/", to_literal(tool_limit), " tools used."))
    response = openai/chat_with_options(requested_model, messages, options)
    let tool_calls = source/openai_tool_calls(response)
    let requested_tool_count = source/agent_tool_call_count(tool_calls)
    log(:info, string_concat("source agent model response received round=", to_literal(model_round), " requested_tools=", to_literal(requested_tool_count)))
    if tool_calls == []
      break
    end
    if requested_tool_count > tool_limit - tool_count
      guard_reason = string_concat("tool request would exceed the remaining budget (requested ", to_literal(requested_tool_count), ", remaining ", to_literal(tool_limit - tool_count), ")")
      break
    end
    let assistant_message = source/openai_first_message(response)
    if assistant_message != nothing
      messages = [@messages, assistant_message]
    end
    for call in tool_calls
      if tool_count >= tool_limit
        guard_reason = string_concat("tool budget reached at ", to_literal(tool_limit), " calls")
        break
      end
      let signature = source/agent_tool_call_signature(call)
      if signature == last_tool_signature
        repeated_tool_count = repeated_tool_count + 1
      else
        last_tool_signature = signature
        repeated_tool_count = 1
      end
      if repeated_tool_count > 2
        guard_reason = string_concat("same tool call repeated ", to_literal(repeated_tool_count), " times")
        break
      end
      tool_count = tool_count + 1
      let tool_message = source/run_agent_tool(assistant_turn, tool_count, call, actor)
      messages = [@messages, tool_message]
      let request = source/agent_tool_request_value(assistant_turn, tool_count)
      let request_row = one source/AgentToolRequest(request, ?ordinal, ?tool, ?args, ?status)
      let tool_status = request_row[:status]
      if tool_status == "complete"
        consecutive_tool_failures = 0
      else
        consecutive_tool_failures = consecutive_tool_failures + 1
      end
      if consecutive_tool_failures >= 3
        guard_reason = string_concat("tool calls failed or were rejected ", to_literal(consecutive_tool_failures), " times in a row")
        break
      end
    end
    model_round = model_round + 1
  end
  if response == nothing
    log(:info, string_concat("source agent fallback model request started model=", requested_model))
    source/update_agent_turn_progress(assistant_turn, string_concat("Calling model without tools for ", requested_model, "."))
    response = openai/chat_with_options(requested_model, messages, {:temperature -> 0.2})
  end
  if guard_reason != "" || source/openai_tool_calls(response) != []
    if guard_reason == ""
      guard_reason = "model requested more tools after tool use was disabled"
    end
    log(:warn, string_concat("source agent tool guard triggered reason=", guard_reason, " tools_used=", to_literal(tool_count), "/", to_literal(tool_limit), " model=", requested_model))
    source/update_agent_turn_progress(assistant_turn, string_concat("Synthesizing answer from ", to_literal(tool_count), " tool results."))
    let final_instruction = string_concat("Stop using tools now. Reason: ", guard_reason, ". Answer the user's request from the tool results already gathered. Give a concise explanation or file/path pointers first. Do not dump raw tool output as the answer. If the gathered evidence is incomplete, say exactly what remains uncertain and which files or symbols would need follow-up.")
    response = openai/chat_with_options(requested_model, [@messages, openai/user_message(final_instruction)], {:temperature -> 0.2})
  end
  let assistant_text = openai/assistant_text(response)
  if assistant_text == nothing
    if source/openai_tool_calls(response) != []
      assistant_text = "The model returned tool calls instead of a final answer after tool use was disabled. Please retry or ask a narrower question."
    else
      assistant_text = "The model returned no assistant text."
    end
  end
  let resolved_model = response[:model]
  if resolved_model == nothing
    resolved_model = requested_model
  end

  retract source/AgentTurnText(assistant_turn, _)
  retract source/AgentTurnStatus(assistant_turn, _)
  retract source/AgentTurnResolvedModel(assistant_turn, _)
  assert source/AgentTurnText(assistant_turn, assistant_text)
  assert source/AgentTurnStatus(assistant_turn, "complete")
  assert source/AgentTurnResolvedModel(assistant_turn, resolved_model)
  source/record_agent_turn_citations(assistant_turn, plan, actor)

  retract source/SelectedAgentStatus(endpoint, _)
  assert source/SelectedAgentStatus(endpoint, "complete")
  source/bump_revision(endpoint)
  log(:info, "source agent prompt completion finished")
  return {:turn -> assistant_turn, :text -> assistant_text, :model -> resolved_model, :plan -> plan}
end

verb source/run_agent_prompt(endpoint, actor, user_text @ #string)
  if user_text == ""
    return nothing
  end

  retract source/SelectedAgentStatus(endpoint, _)
  assert source/SelectedAgentStatus(endpoint, "working")
  source/record_agent_user_turn(endpoint, user_text)
  return source/complete_agent_prompt(endpoint, actor, user_text)
end

verb source/start_agent_prompt(endpoint, actor, user_text @ #string)
  if user_text == ""
    return nothing
  end

  log(:info, "source agent prompt queued")
  retract source/SelectedAgentStatus(endpoint, _)
  assert source/SelectedAgentStatus(endpoint, "working")
  let user_turn = source/record_agent_user_turn(endpoint, user_text)
  if user_turn == nothing
    return nothing
  end

  let child = spawn :source/complete_agent_prompt(endpoint: endpoint, actor: actor, user_text: user_text) after 0
  return child
end

verb source/record_answer_findings(answer, provider @ #string, model @ #string)
  let count = 0
  for found in AnswerCitation(answer, ?subject)
    let subject = found[:subject]
    let finding = frob(#source/agent_finding, {:answer -> answer, :subject -> subject})
    let text = one AnswerText(answer, ?text)
    if text == nothing
      text = ""
    end
    assert source/AgentFinding(finding)
    assert source/FindingAnswer(finding, answer)
    assert source/FindingSubject(finding, subject)
    assert source/FindingText(finding, text)
    assert source/FindingStatus(finding, "pending")
    assert source/FindingProvider(finding, provider)
    assert source/FindingModel(finding, model)
    count = count + 1
  end
  return count
end

verb source/generate_answer_for_plan(endpoint, actor, plan)
  let question = one PlanForQuestion(plan, ?question)
  let question_text = one QuestionText(question, ?text)
  if question == nothing || question_text == nothing
    return nothing
  end

  let context_text = source/answer_context_text(plan, actor)
  if context_text == ""
    return nothing
  end

  let requested_model = source/generation_model()
  let provider = source/generation_provider()
  let prompt = source/answer_prompt_text(question_text, context_text)
  let response = openai/chat_with_options(requested_model, [openai/system_message("Answer from cited Mica source context only."), openai/user_message(prompt)], {:temperature -> 0.2})
  let answer_text = openai/assistant_text(response)
  if answer_text == nothing
    answer_text = json_encode(response)
  end
  let resolved_model = response[:model]
  if resolved_model == nothing
    resolved_model = requested_model
  end

  let answer = retrieval/answer_value(question, #source/retrieval_index, source/retrieval_limit(), requested_model)
  assert Answer(answer)
  assert AnswerForQuestion(answer, question)
  assert AnswerPromptText(answer, prompt)
  assert AnswerContextText(answer, context_text)
  assert AnswerText(answer, answer_text)
  assert AnswerStatus(answer, "generated")
  assert AnswerNeedsReview(answer)
  assert source/AnswerPlan(answer, plan)
  assert source/AnswerProvider(answer, provider)
  assert source/AnswerModel(answer, requested_model)
  assert source/AnswerResolvedModel(answer, resolved_model)
  assert source/AnswerReviewStatus(answer, "pending")
  assert source/RetrievalArtifact(answer)
  assert source/RetrievalArtifactIndex(answer, #source/retrieval_index)
  assert source/RetrievalArtifactRevision(answer, #source/rev_worktree)
  assert source/RetrievalArtifactIndexVersion(answer, source/retrieval_corpus_version())

  for found in ContextForPlan(?context, plan)
    let subject = one ContextSubject(found[:context], ?subject)
    if source/can_retrieve_subject(actor, subject)
      assert AnswerCitation(answer, subject)
      let text = one source/RetrievalCitationText(plan, subject, ?text)
      if text == nothing
        text = source/retrieval_text_unit_text(subject)
      end
      if text != nothing
        assert AnswerCitationText(answer, subject, text)
      end
    end
  end

  source/record_answer_findings(answer, provider, resolved_model)
  retract source/SelectedGeneratedAnswer(endpoint, _)
  assert source/SelectedGeneratedAnswer(endpoint, answer)
  assert source/SelectedRetrievalStatus(endpoint, "generated answer pending review")
  return {:answer -> answer, :text -> answer_text, :model -> resolved_model}
end

verb source/generate_answer_for_selected_plan(endpoint, actor)
  let plan = one source/SelectedRetrievalPlan(endpoint, ?plan)
  if plan == nothing
    return nothing
  end

  return source/generate_answer_for_plan(endpoint, actor, plan)
end

verb source/accept_answer(answer)
  if Answer(answer) == false
    return false
  end
  retract source/AnswerReviewStatus(answer, _)
  assert source/AnswerReviewStatus(answer, "accepted")
  retract AnswerStatus(answer, _)
  assert AnswerStatus(answer, "reviewed")
  retract AnswerNeedsReview(answer)
  return true
end

verb source/reject_answer(answer)
  if Answer(answer) == false
    return false
  end
  retract source/AnswerReviewStatus(answer, _)
  assert source/AnswerReviewStatus(answer, "rejected")
  retract AnswerStatus(answer, _)
  assert AnswerStatus(answer, "rejected")
  retract AnswerNeedsReview(answer)
  return true
end

verb source/correct_answer(answer, text @ #string)
  if Answer(answer) == false
    return false
  end
  retract AnswerText(answer, _)
  assert AnswerText(answer, text)
  retract source/AnswerReviewStatus(answer, _)
  assert source/AnswerReviewStatus(answer, "corrected")
  retract AnswerStatus(answer, _)
  assert AnswerStatus(answer, "corrected")
  retract AnswerNeedsReview(answer)
  return true
end

verb source/accept_finding(finding)
  if source/AgentFinding(finding) == false
    return false
  end
  retract source/FindingStatus(finding, _)
  assert source/FindingStatus(finding, "accepted")
  assert source/AcceptedAgentFinding(finding)
  return true
end

verb source/reject_finding(finding)
  if source/AgentFinding(finding) == false
    return false
  end
  retract source/FindingStatus(finding, _)
  assert source/FindingStatus(finding, "rejected")
  retract source/AcceptedAgentFinding(finding)
  return true
end

verb source/correct_finding(finding, text @ #string)
  if source/AgentFinding(finding) == false
    return false
  end
  retract source/FindingText(finding, _)
  assert source/FindingText(finding, text)
  retract source/FindingStatus(finding, _)
  assert source/FindingStatus(finding, "corrected")
  retract source/AcceptedAgentFinding(finding)
  return true
end

verb source/run_retrieval_query(endpoint, actor, question_text @ #string)
  return source/run_retrieval_query_with_scope(endpoint, actor, question_text, source/default_retrieval_scope())
end

verb source/run_retrieval_query_with_scope(endpoint, actor, question_text @ #string, scope)
  let model = source/retrieval_model()
  let limit = source/retrieval_limit()
  let normalised_scope = source/normalise_retrieval_scope(scope)
  if source/retrieval_prewarm_complete() == false
    source/clear_retrieval_session(endpoint)
    assert source/SelectedRetrievalQuestion(endpoint, question_text)
    assert source/SelectedRetrievalModel(endpoint, model)
    assert source/SelectedRetrievalLimit(endpoint, limit)
    assert source/SelectedRetrievalScope(endpoint, normalised_scope)
    assert source/SelectedRetrievalSemanticStatus(endpoint, "indexing")
    assert source/SelectedRetrievalStatus(endpoint, "indexing source")
    return {:contexts -> [], :count -> 0, :plan -> nothing, :question -> nothing}
  end

  let retrieval = source/search_context(actor, question_text, limit, normalised_scope, model)
  let plan = retrieval[:plan]
  let contexts = retrieval[:contexts]
  let count = 0

  source/clear_retrieval_session(endpoint)
  assert source/SelectedRetrievalQuestion(endpoint, question_text)
  assert source/SelectedRetrievalPlan(endpoint, plan)
  assert source/SelectedRetrievalModel(endpoint, model)
  assert source/SelectedRetrievalLimit(endpoint, limit)
  assert source/SelectedRetrievalScope(endpoint, normalised_scope)
  assert source/SelectedRetrievalSemanticStatus(endpoint, retrieval[:semantic_status])

  let artifact_index = #source/retrieval_index
  let index_version = "worktree"
  for index_row in source/SourceIndex(?index)
    let candidate = one source/IndexVersion(index_row[:index], ?version)
    if candidate != nothing
      artifact_index = index_row[:index]
      index_version = candidate
      break
    end
  end

  assert source/RetrievalArtifact(plan)
  assert source/RetrievalArtifactIndex(plan, artifact_index)
  assert source/RetrievalArtifactRevision(plan, #source/rev_worktree)
  assert source/RetrievalArtifactIndexVersion(plan, index_version)

  for item in contexts
    let subject = item[:subject]
    assert source/RetrievalCitation(plan, subject)
    count = count + 1
  end

  assert source/SelectedRetrievalStatus(endpoint, string_concat(to_literal(count), " search results"))
  return {:contexts -> contexts, :count -> count, :plan -> plan, :question -> retrieval[:question]}
end

verb source/run_symbol_neighbourhood_query(endpoint, actor, symbol)
  let name = one source/SelectedSymbolName(endpoint, ?name)
  let kind = one source/SelectedSymbolKind(endpoint, ?kind)
  if name == nothing
    name = to_literal(symbol)
  end
  if kind == nothing
    kind = "symbol"
  end

  let query = string_concat("symbol neighbourhood for ", name, " ", kind)
  let retrieval = source/run_retrieval_query(endpoint, actor, query)
  let plan = retrieval[:plan]
  retract PlanKind(plan, _)
  assert PlanKind(plan, "source_symbol_neighbourhood")
  return retrieval
end
