assert source/RetrievalTextUnitStartLine(#source/text_file_ui_session, 1)
assert source/RetrievalTextUnitEndLine(#source/text_file_ui_session, 80)
assert source/RetrievalTextUnitModel(#source/text_file_ui_session, "source-workspace")

