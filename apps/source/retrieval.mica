assert source/RetrievalTextUnitKind(#source/text_file_runtime, "file")
assert source/RetrievalTextUnitTitle(#source/text_file_runtime, "Runtime source execution")
assert source/RetrievalTextUnitFile(#source/text_file_runtime, #source/file_runtime_lib)
assert source/RetrievalTextUnitStartLine(#source/text_file_runtime, 1)
assert source/RetrievalTextUnitEndLine(#source/text_file_runtime, 80)
assert source/RetrievalTextUnitModel(#source/text_file_runtime, "source-workspace")

