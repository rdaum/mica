CanRetrieveSubject(actor, subject) :-
  source/RetrievalTextUnitFile(subject, file),
  source/CanReadSourceFile(actor, file)

CanRetrieveSubject(actor, subject) :-
  source/RetrievalTextUnitSpan(subject, span),
  source/CanReadSourceSpan(actor, span)

verb source/retrieval_model()
  return "source-workspace"
end

verb source/retrieval_limit()
  return 8
end

verb source/retrieval_text_unit_path(unit)
  let file = one source/RetrievalTextUnitFile(unit, ?file)
  if file == nothing
    return nothing
  end

  return one source/FilePath(file, ?path)
end

verb source/retrieval_text_unit_line(unit)
  let line = one source/RetrievalTextUnitStartLine(unit, ?line)
  if line == nothing
    return 1
  end

  return line
end

verb source/retrieval_subject_status(subject, model @ #string)
  let text = one TextUnitText(subject, ?text)
  if text == nothing
    return "missing"
  end

  return retrieval/index_entry_status(#source/retrieval_index, subject, model, text)
end

verb source/index_retrieval_subjects(actor, model @ #string)
  let indexed = 0
  for found in TextUnit(?subject)
    let subject = found[:subject]
    if source/RetrievalTextUnitModel(subject, model) && CanRetrieveSubject(actor, subject)
      let text = one TextUnitText(subject, ?text)
      ensure_subject_embedding(actor, #source/retrieval_index, subject, text, model)
      indexed = indexed + 1
    end
  end

  return indexed
end

verb source/clear_retrieval_session(endpoint)
  retract source/SelectedRetrievalQuestion(endpoint, _)
  retract source/SelectedRetrievalPlan(endpoint, _)
  retract source/SelectedRetrievalModel(endpoint, _)
  retract source/SelectedRetrievalLimit(endpoint, _)
  retract source/SelectedRetrievalStatus(endpoint, _)
  return true
end

verb source/run_retrieval_query(endpoint, actor, question_text @ #string)
  let model = source/retrieval_model()
  let limit = source/retrieval_limit()
  source/index_retrieval_subjects(actor, model)
  let retrieval = retrieve_context(actor, #source/retrieval_index, question_text, limit, model)
  let plan = retrieval[:plan]
  let contexts = retrieval[:contexts]
  let count = 0

  source/clear_retrieval_session(endpoint)
  assert source/SelectedRetrievalQuestion(endpoint, question_text)
  assert source/SelectedRetrievalPlan(endpoint, plan)
  assert source/SelectedRetrievalModel(endpoint, model)
  assert source/SelectedRetrievalLimit(endpoint, limit)

  let artifact_index = #source/retrieval_index
  let index_version = "worktree"
  for index_row in source/SourceIndex(?index)
    let candidate = one source/IndexVersion(index_row[:index], ?version)
    if candidate != nothing
      artifact_index = index_row[:index]
      index_version = candidate
      break
    end
  end

  assert source/RetrievalArtifact(plan)
  assert source/RetrievalArtifactIndex(plan, artifact_index)
  assert source/RetrievalArtifactRevision(plan, #source/rev_worktree)
  assert source/RetrievalArtifactIndexVersion(plan, index_version)

  for item in contexts
    let subject = item[:subject]
    let text = one TextUnitText(subject, ?text)
    assert source/RetrievalCitation(plan, subject)
    assert source/RetrievalCitationText(plan, subject, text)
    count = count + 1
  end

  assert source/SelectedRetrievalStatus(endpoint, string_concat(to_literal(count), " context items"))
  return {:contexts -> contexts, :count -> count, :plan -> plan, :question -> retrieval[:question]}
end

verb source/run_symbol_neighbourhood_query(endpoint, actor, symbol)
  let name = one source/SelectedSymbolName(endpoint, ?name)
  let kind = one source/SelectedSymbolKind(endpoint, ?kind)
  if name == nothing
    name = to_literal(symbol)
  end
  if kind == nothing
    kind = "symbol"
  end

  let query = string_concat("symbol neighbourhood for ", name, " ", kind)
  let retrieval = source/run_retrieval_query(endpoint, actor, query)
  let plan = retrieval[:plan]
  retract PlanKind(plan, _)
  assert PlanKind(plan, "source_symbol_neighbourhood")
  return retrieval
end
