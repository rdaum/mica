verb source/handle_sync_action(source @ #source/correct_answer_action<_>, endpoint, session, view, event, target, fields)
  if source/View(view) == false || event != "submit"
    return false
  end

  let raw_answer = fields[:answer]
  let text = fields[:text]
  if raw_answer == nothing || text == nothing || text == ""
