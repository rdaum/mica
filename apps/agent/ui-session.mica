// Server-owned UI session state and sync action selectors for the agent app.

make_relation(:ui/View, 1)
make_functional_relation(:ui/SyncAction, 2, [0])
make_functional_relation(:session/Actor, 2, [0], :volatile)
make_functional_relation(:session/Inspect, 2, [0], :volatile)
make_functional_relation(:session/InspectPulse, 2, [0], :volatile)
make_functional_relation(:session/TranscriptLimit, 2, [0], :volatile)
make_functional_relation(:session/CommandDraft, 2, [0], :volatile)
make_functional_relation(:session/ObjectBrowserQuery, 2, [0], :volatile)

make_identity(:ui/sync_action)
make_identity(:ui/inspect_action)
make_identity(:ui/command_action)
make_identity(:ui/load_older_messages_action)
make_identity(:ui/object_browser_search_action)
make_identity(:ui/select_workspace_action)

assert ui/View(31)
assert Delegates(#ui/inspect_action, #ui/sync_action, 0)
assert Delegates(#ui/command_action, #ui/sync_action, 0)
assert Delegates(#ui/load_older_messages_action, #ui/sync_action, 0)
assert Delegates(#ui/object_browser_search_action, #ui/sync_action, 0)
assert Delegates(#ui/select_workspace_action, #ui/sync_action, 0)
"agent_inspect".ui/syncAction = #ui/inspect_action
"agent_command".ui/syncAction = #ui/command_action
"agent_load_older_messages".ui/syncAction = #ui/load_older_messages_action
"agent_object_browser_search".ui/syncAction = #ui/object_browser_search_action
"agent_select_workspace".ui/syncAction = #ui/select_workspace_action

grant #web
  read:
    :ui/View
    :ui/SyncAction
    :session/Actor
    :session/Inspect
    :session/InspectPulse
    :session/TranscriptLimit
    :session/CommandDraft
    :session/ObjectBrowserQuery
    :session/IsStreaming
    :session/LoopPhase
    :session/SteeringQueue
    :session/FollowUpQueue
    :Delegates
    :Name
    :Description
    :Agent
    :AgentWorkspace
    :AgentModel
    :Workspace
    :WorkspaceRoot
    :WorkspaceProvider
    :WorkspaceRevision
    :Transcript
    :TranscriptAgent
    :TranscriptWorkspace
    :Message
    :MessageTranscript
    :MessageSeq
    :MessageRole
    :MessageContent
    :InspectorTarget
    :InspectorKind
    :InspectorLabel
    :InspectorLocation
  write:
    :session/Actor
    :session/Inspect
    :session/InspectPulse
    :session/TranscriptLimit
    :session/CommandDraft
    :session/ObjectBrowserQuery
    :session/IsStreaming
    :session/LoopPhase
    :session/SteeringQueue
    :session/FollowUpQueue
    :Transcript
    :TranscriptAgent
    :TranscriptWorkspace
    :Message
    :MessageTranscript
    :MessageSeq
    :MessageRole
    :MessageContent
  invoke:
    :sync_event
    :sync_view_dependencies
    :sync_view_tree
    :ui/auth_required_node
    :ui/fact_dependency
    :ui/transcript_cutoff
    :ui/current_agent
    :ui/entity_from_literal
    :agent/name
    :workspace/name
    :string_concat
    :lower
    :trim
end

CanRead(#web, relation) :-
  RoleCanRead(#operator, relation)

CanWrite(#web, relation) :-
  RoleCanWrite(#operator, relation)

CanInvoke(#web, selector) :-
  RoleCanInvoke(#operator, selector)

CanEffect(#web) :-
  RoleCanEffect(#operator)

