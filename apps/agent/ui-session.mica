    :ui/current_agent
    :ui/entity_from_literal
    :ui/can_inspect_entity
    :ui/agent_name
    :ui/workspace_name
    :ui/workspace_root_text
    :ui/target_kind_label
    :ui/auth_required_node
    :ui/icon_node
    :ui/icon_label_node
    :ui/command_form_node
    :ui/entity_action_node
    :ui/world_view_node
    :ui/world_tools_node
    :ui/workspace_panel_node
    :ui/object_browser_panel_node
    :ui/object_browser_results_node
    :ui/object_browser_row_node
    :ui/object_browser_matches
    :ui/object_browser_description
    :ui/inspector_node
    :ui/entity_fact_node
    :ui/entity_facts_node
    :ui/inspector_action_node
    :ui/transcript_node
