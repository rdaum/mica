    :frob_delegate
    :actor
end

verb ui/current_agent()
  let current = actor()
  if current != nothing && Delegates(current, #agent, 0)
    return current
  end
  return #agent/default
end

verb ui/agent_name(agent @ #agent)
  return agent/name(agent)
end

verb ui/workspace_name(workspace)
  return workspace/name(workspace)
end

verb ui/workspace_root_text(workspace)
  let root = workspace.workspaceRoot
  if root == nothing
    return ""
  end
  return root
end

verb ui/target_kind_label(kind @ #string)
  return target/kind_label(kind)
end

verb ui/entity_from_literal(text)
  if text == nothing
    return nothing
  end
  return from_literal(text)
end

verb ui/can_inspect_entity(agent @ #agent, entity)
  if entity == nothing
    return false
  end
  return true
end

verb ui/status_revision()
  let current = ui/current_agent()
  let revision = 1
  let transcript = agent/transcript(current)
  if transcript != nothing
    for message in agent/messages(transcript)
      let seq = message.messageSeq
      if seq > revision || seq == revision
        revision = seq + 1
      end
    end
  end
  revision = revision * 2

  let ui_revision = endpoint().session/revision
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end

  return revision
end

verb ui/bump_revision(endpoint)
  let current = ui/current_agent()
  let revision = 1
  let transcript = agent/transcript(current)
  if transcript != nothing
    for message in agent/messages(transcript)
      let seq = message.messageSeq
      if seq > revision || seq == revision
        revision = seq + 1
      end
    end
  end
  revision = revision * 2

  let ui_revision = endpoint.session/revision
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end
  revision = revision + 1

  endpoint.session/revision = revision
  return revision
end

verb sync_view_revision(view)
  if ui/View(view) == false
    return 0
  end
  return ui/status_revision()
end

verb sync_view_tree(view, revision)
  let current = ui/current_agent()
  if ui/View(view) == false || current == nothing
    return ui/auth_required_node()
  end
  let limit = endpoint().session/transcriptLimit
  if limit == nothing
    limit = 40
  end
  return ui/world_view_node(current, revision, limit)
end