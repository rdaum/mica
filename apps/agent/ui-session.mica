    :AgentModel
    :Workspace
    :WorkspaceRoot
    :WorkspaceProvider
    :WorkspaceRevision
    :Transcript
    :TranscriptAgent
    :TranscriptWorkspace
    :Message
    :MessageTranscript
    :MessageSeq
    :MessageRole
    :MessageContent
    :InspectorTarget
    :InspectorKind
    :InspectorLabel
    :InspectorLocation
    :Description
    :Builder
    :HttpRequest
    :RequestMethod
    :RequestPath
    :RequestVersion
    :RequestPrincipal
    :RequestActor
    :RequestHeader
    :RequestBody
  write:
    :session/Inspect
    :session/InspectPulse
    :session/TranscriptLimit
    :session/Revision
    :session/CommandDraft
