verb ui/current_agent()
  let current = actor()
  if current != nothing && Delegates(current, #agent, 0)
    return current
  end
  return #agent/default
end

verb ui/agent_name(agent @ #agent)
  return agent/name(agent)
end

verb ui/workspace_name(entity)
  if is_frob(entity)
    let delegate = frob_delegate(entity)
    if delegate == #target/file
      return frob_value(entity)
    end
    return to_literal(entity)
  end
  return workspace/name(entity)
end

verb ui/workspace_root_text(workspace)
  let root = workspace.workspaceRoot
  if root == nothing
    return ""
  end
  return root
end

verb ui/target_kind_label(kind @ #string)
  return target/kind_label(kind)
end

verb ui/entity_from_literal(text)
  if text == nothing
    return nothing
  end
  return from_literal(text)
end

verb ui/can_inspect_entity(agent @ #agent, entity)
  if entity == nothing
    return false
  end
  return true
end

verb ui/transcript_cutoff()
  let current = ui/current_agent()
  let revision = 1
  let transcript = agent/transcript(current)
  if transcript != nothing
    for message in agent/messages(transcript)
      let seq = message.messageSeq
      if seq > revision || seq == revision
        revision = seq + 1
      end
    end
  end
  return revision
end

verb ui/fact_dependency(relation, bindings)
  return {:subject -> :facts, :relation -> relation, :bindings -> bindings}
end

// Commit partial tool-loop progress so relation subscriptions can push it while
// the sync_event task remains active.
verb ui/flush(endpoint)
  commit()
  return nothing
end

verb sync_view_dependencies(view)
  let endpoint = endpoint()
  let dependencies = []
  dependencies = [@dependencies, ui/fact_dependency(:ui/View, [view])]
  dependencies = [@dependencies, ui/fact_dependency(:session/Actor, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/Inspect, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/InspectPulse, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/TranscriptLimit, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/CommandDraft, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/ObjectBrowserQuery, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/IsStreaming, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/LoopPhase, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/SteeringQueue, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:session/FollowUpQueue, [endpoint, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Delegates, [nothing, nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Name, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Description, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Agent, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:AgentWorkspace, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:AgentModel, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Workspace, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:WorkspaceRoot, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:WorkspaceProvider, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:WorkspaceRevision, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Transcript, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:TranscriptAgent, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:TranscriptWorkspace, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Message, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:MessageTranscript, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:MessageSeq, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:MessageRole, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:MessageContent, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:Tool, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolName, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolDescription, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolParameters, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolEnabled, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCall, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCallMessage, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCallId, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCallName, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCallArguments, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolCallStatus, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolResult, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolResultCall, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolResultContent, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolResultIsError, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:ToolResultDetails, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/Repository, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RepositoryName, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RepositoryRoot, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RepositoryProvider, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/Revision, [nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RevisionOf, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RevisionKind, [nothing, nothing])]
  dependencies = [@dependencies, ui/fact_dependency(:source/RevisionLabel, [nothing, nothing])]
  return dependencies
end

verb sync_view_tree(view)
  let current = ui/current_agent()
  if ui/View(view) == false || current == nothing
    return ui/auth_required_node()
  end
  let limit = endpoint().session/transcriptLimit
  if limit == nothing
    limit = 40
  end
  let revision = ui/transcript_cutoff()
  return ui/world_view_node(current, revision, limit)
end
