// HTTP document route for the DOM-synced agent app.

grant #web
  read:
    :HttpRequest
    :RequestMethod
    :RequestPath
    :source/IndexedFile
  invoke:
    :http_request
    :http/document
    :http/base_style
    :http/bootstrap_script
    :http_json
    :dom_text
    :dom_element
    :dom_raw
    :to_xml
    :json_encode
    :string_starts_with
    :string_contains
    :string_len
    :string_slice
    :lower
    :trim
    :ui/current_agent
    :workspace/active
    :tool/source_repository
    :tool/source_revision
    :agent/completions_payload
end

verb http_request(request)
  let http_method = one RequestMethod(request, ?m)
  let path = one RequestPath(request, ?path)

  if http_method == "GET" && (path == "/" || path == "/agent" || string_starts_with(path, "/agent?"))
    return http_html(200, http/document(31))
  end

  if http_method == "GET" && string_starts_with(path, "/agent/api/completions")
    return http_json(200, agent/completions_payload(path))
  end

  return http_text(404, "not found")
end

verb agent/completions_payload(path)
  let query = ""
  let marker = "?q="
  let marker_len = string_len(marker)
  let path_len = string_len(path)
  let pos = 0
  let found_at = -1
  while pos + marker_len <= path_len
    let slice = string_slice(path, pos, pos + marker_len)
    if slice == marker
      found_at = pos
      pos = path_len
    else
      pos = pos + 1
    end
  end
  if found_at >= 0
    query = lower(trim(string_slice(path, found_at + marker_len, path_len)))
  end
  let limit = 20
  let items = []
  let count = 0
  for row in source/IndexedFile(?idx, ?repo, ?filepath, ?filetitle, ?lang, ?model)
    if count < limit && (query == "" || string_contains(lower(row[:filepath]), query))
      let item = {:path -> row[:filepath], :title -> row[:filetitle], :language -> row[:lang], :kind -> "file"}
      items = [@items, item]
      count = count + 1
    end
  end
  let agent = ui/current_agent()
  if agent != nothing
    let workspace = workspace/active(agent)
    if workspace != nothing
      let repository = tool/source_repository(workspace)
      let revision = tool/source_revision(workspace)
      if repository != nothing && revision != nothing
        for entry_row in source/RepositoryEntry(repository, revision, "", ?child_path, ?kind, ?entry_name)
          if count < limit && entry_row[:kind] == "directory"
            let dir_path = entry_row[:child_path]
            if query == "" || string_contains(lower(dir_path), query)
              let item = {:path -> dir_path, :title -> entry_row[:entry_name], :language -> "", :kind -> "directory"}
              items = [@items, item]
              count = count + 1
            end
          end
        end
      end
    end
  end
  return json_encode({:items -> items})
end

verb http/document(view)
  let snapshot = sync_snapshot(view)
  let payload = sync_snapshot_payload(view)
  let signature = sync_snapshot_signature(view, payload)
  let root = sync_snapshot_tree(view)
  let mount = sync_mount_node(view, snapshot[:revision], signature, root)
  let head = dom <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mica Agent</title>
    <style>{dom_raw(http/base_style())}</style>
  </head>
  let body = dom <body>
    {mount}
    <script type="module">{dom_raw(http/bootstrap_script())}</script>
  </body>
  return to_xml([dom_raw("<!doctype html>"), dom <html lang="en">{head}{body}</html>])
end

verb http/base_style()
  return include_text("style.css")
end

verb http/bootstrap_script()
  return include_text("bootstrap.js")
end