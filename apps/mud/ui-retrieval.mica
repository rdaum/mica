// Retrieval-backed inspector panel for the browser MUD view.

make_identity(:ui/retrieval_action)
make_identity(:retrieval/mud_world)

make_functional_relation(:session/RetrievalPlan, 2, [0])

assert Delegates(#ui/retrieval_action, #ui/sync_action, 0)
assert ui/SyncAction("mud_retrieve_related", #ui/retrieval_action)

assert RoleCanRead(#player, :session/RetrievalPlan)
assert RoleCanWrite(#player, :session/RetrievalPlan)

assert RoleCanInvoke(#player, :ui/retrieval_model)
assert RoleCanInvoke(#player, :ui/retrieval_index)
