verb ui/retrieval_model()
  return "mud-world"
end

verb ui/retrieval_index()
  return #retrieval/mud_world
end

verb ui/retrieval_text(entity)
  let text = ui/actor_name(entity)
  let description = one Description(entity, ?description)
  if description != nothing
    text = string_concat(text, string_concat(": ", description))
  end
  return text
end

verb ui/retrieval_seed_world(actor @ #player)
  let index = ui/retrieval_index()
  let model = ui/retrieval_model()
  assert VectorIndex(index)
  assert VectorIndexMetric(index, "cosine")

  let entities = [#alice, #bob, #coin, #box, #red_button, #first_room, #north_room, #attic]
  for entity in entities
    assert TextUnit(entity)
    retract TextUnitText(entity, _)
    assert TextUnitText(entity, ui/retrieval_text(entity))
    index_text_unit(actor, index, entity, model)
  end
  return true
end

verb ui/retrieval_query_selected(actor @ #player, endpoint, selected)
  ui/retrieval_seed_world(actor)
  let retrieval = retrieve_context(actor, ui/retrieval_index(), ui/retrieval_text(selected), 5, ui/retrieval_model())
  retract session/RetrievalPlan(endpoint(), _)
  retract session/RetrievalPlan(endpoint, _)
  assert session/RetrievalPlan(endpoint(), retrieval[:plan])
  assert session/RetrievalPlan(endpoint, retrieval[:plan])
  ui/bump_revision(endpoint)
  return retrieval[:plan]
end

verb ui/retrieval_action_node()
  let button = dom_element("button", {:class -> "mini-button retrieval-button", :type -> "submit"}, [dom_text("Related context")])
  return dom_element("form", {:class -> "mud-action retrieval-action", "data-sync-event" -> "submit", "data-sync-action" -> "mud_retrieve_related"}, [button])
end

verb ui/retrieval_result_row_node(actor @ #player, subject, score, status @ #string)
  let inspect = ui/entity_action_node(string_concat("related-", to_literal(subject)), subject, string_concat("look ", ui/actor_name(subject)), ui/actor_name(subject), "entity-button related-link")
  let meta = dom_element("div", {:class -> "retrieval-meta"}, [dom_element("span", {:class -> string_concat("retrieval-status retrieval-status-", status)}, [dom_text(status)]), dom_element("span", {:class -> "retrieval-score"}, [dom_text(to_literal(score))])])
  return dom_element("li", {"data-sync-key" -> to_literal(subject), :class -> "retrieval-row"}, [inspect, meta])
end

verb ui/retrieval_panel_node(actor @ #player, selected)
  let children = [dom_element("div", {:class -> "retrieval-toolbar"}, [ui/retrieval_action_node()])]
  let plan = one session/RetrievalPlan(endpoint(), ?plan)
  if plan == nothing
    children = [@children, dom_element("p", {:class -> "muted"}, [dom_text("Run retrieval to see related rooms, people, and objects.")])]
    return dom_element("section", {:class -> "panel retrieval-panel"}, [dom_element("h3", {}, [dom_text("Related context")]), @children])
  end

  let items = []
  for found in ContextForPlan(?context, plan)
    let context = found[:context]
    let subject = one ContextSubject(context, ?subject)
    if subject != selected && CanSee(actor, subject)
      let score = one ContextScore(context, ?score)
      let status = one IndexEntryStatus(ui/retrieval_index(), subject, ui/retrieval_model(), ?status)
      if status == nothing
        status = "unknown"
      end
      items = [@items, ui/retrieval_result_row_node(actor, subject, score, status)]
    end
  end

  if items == []
    children = [@children, dom_element("p", {:class -> "muted"}, [dom_text("No related context found yet.")])]
  else
    children = [@children, dom_element("ul", {:class -> "retrieval-results"}, items)]
  end
  return dom_element("section", {:class -> "panel retrieval-panel"}, [dom_element("h3", {}, [dom_text("Related context")]), @children])
end

verb ui/handle_sync_action(source @ #ui/retrieval_action<_>, endpoint, session, view, event, target, fields)
  if ui/View(view) == false || event != "submit"
    return false
  end

  let current = ui/current_actor()
  let selected = one session/Inspect(endpoint, ?selected)
  if current == nothing || selected == nothing || CanSee(current, selected) == false
    return false
  end

  ui/retrieval_query_selected(current, endpoint, selected)
  event/record_text(current, string_concat("> related ", ui/actor_name(selected)))
  return true
end
