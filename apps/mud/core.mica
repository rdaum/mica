assert command/Pattern(:look, :look, #command/pattern/look_room)
assert command/PatternPart(#command/pattern/look_room, 0, :eol, nothing)

assert command/Pattern(:look, :examine, #command/pattern/look_target)
assert command/PatternPart(#command/pattern/look_target, 0, :optional_prep, :at)
assert command/PatternPart(#command/pattern/look_target, 1, :object_role, :target)

assert command/Pattern(:look, :look_in, #command/pattern/look_inside)
assert command/PatternPart(#command/pattern/look_inside, 0, :prep, :inside)
assert command/PatternPart(#command/pattern/look_inside, 1, :object_role, :target)

assert command/Pattern(:north, :north, #command/pattern/north)
assert command/PatternPart(#command/pattern/north, 0, :eol, nothing)

assert command/Pattern(:south, :south, #command/pattern/south)
assert command/PatternPart(#command/pattern/south, 0, :eol, nothing)

assert command/Pattern(:up, :up, #command/pattern/up)
assert command/PatternPart(#command/pattern/up, 0, :eol, nothing)

assert command/Pattern(:down, :down, #command/pattern/down)
assert command/PatternPart(#command/pattern/down, 0, :eol, nothing)

assert command/Pattern(:get, :get, #command/pattern/get)
assert command/PatternPart(#command/pattern/get, 0, :object_role, :item)

assert command/Pattern(:get, :get_from, #command/pattern/get_from)
assert command/PatternPart(#command/pattern/get_from, 0, :object_role, :item)
assert command/PatternPart(#command/pattern/get_from, 1, :prep, :from)
assert command/PatternPart(#command/pattern/get_from, 2, :object_role, :container)

assert command/Pattern(:drop, :drop, #command/pattern/drop)
assert command/PatternPart(#command/pattern/drop, 0, :object_role, :item)

assert command/Pattern(:put, :put, #command/pattern/put)
assert command/PatternPart(#command/pattern/put, 0, :object_role, :item)
assert command/PatternPart(#command/pattern/put, 1, :optional_prep, :inside)
assert command/PatternPart(#command/pattern/put, 2, :object_role, :container)

assert command/Pattern(:push, :push, #command/pattern/push)
assert command/PatternPart(#command/pattern/push, 0, :object_role, :target)

assert command/Pattern(:say, :say, #command/pattern/say)
assert command/PatternPart(#command/pattern/say, 0, :message, nothing)

assert command/Pattern(:emote, :emote, #command/pattern/emote)
assert command/PatternPart(#command/pattern/emote, 0, :message, nothing)

assert command/Pattern(:nod, :nod, #command/pattern/social_none)
