assert command/PatternPart(#command/pattern/social_target, 0, :object_role, :target)
assert command/PatternPart(#command/pattern/social_at, 0, :prep, :at)
assert command/PatternPart(#command/pattern/social_at, 1, :object_role, :target)
assert command/PatternPart(#command/pattern/social_to, 0, :prep, :to)
assert command/PatternPart(#command/pattern/social_to, 1, :object_role, :target)
assert command/PatternPart(#command/pattern/social_none, 0, :eol, nothing)
assert command/PatternPart(#command/pattern/think, 0, :message, nothing)

assert command/Preposition(:at, "at")
assert command/Preposition(:inside, "in")
assert command/Preposition(:inside, "inside")
assert command/Preposition(:inside, "into")
