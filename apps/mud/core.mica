command/TrustedForName(actor, obj) :-
  Delegates(actor, #player, ?distance),
  command/TrustedForName(#player, obj)

command/TrustedForGrammar(actor, provider) :-
  Delegates(actor, #player, ?distance),
  command/TrustedForGrammar(#player, provider)

Exit(from, command, to) :-
  PassageSide(passage, from, to),
  PassageAlias(passage, from, command),
  PassageOpen(passage, true)

ReachableRoom(area, from, to) :-
  RoomInArea(from, area),
  RoomInArea(to, area),
  Exit(from, command, to)

ReachableRoom(area, from, to) :-
  RoomInArea(from, area),
  RoomInArea(to, area),
  Exit(from, command, middle),
  ReachableRoom(area, middle, to)

Within(item, place) :-
  LocatedIn(item, place)

Within(item, place) :-
  LocatedIn(item, container),
  Within(container, place)

Contents(place, item) :-
  Within(item, place)

Carrying(actor, item) :-
  LocatedIn(item, actor)

CanSee(actor, room) :-
  LocatedIn(actor, room)

CanSee(actor, item) :-
  LocatedIn(actor, room),
  Within(item, room)

CanSee(actor, item) :-
  Carrying(actor, item)

PresentActor(room, actor) :-
  Delegates(actor, #player, depth),
  LocatedIn(actor, room)

command/Name(obj, name) :-
  command/Noun(obj, name)

command/Name(obj, parser_alias) :-
  command/NounAlias(obj, parser_alias)

VisibleTo(actor, obj) :-
  CanSee(actor, obj)

command/NameMatchable(actor, obj) :-
  VisibleTo(actor, obj),
  command/TrustedForName(actor, obj)

command/GrammarSource(actor, provider) :-
  command/TrustedForGrammar(actor, provider)

command/HandlerScope(actor, actor) :-
  command/TrustedForGrammar(actor, actor)

command/HandlerScope(actor, room) :-
  LocatedIn(actor, room)

verb event/next_seq(listener @ #player)
  let seq = 0
  for found in event/Delivery(listener, ?event)
    let event_seq = found[:event].event/seq
    if event_seq > seq
      seq = event_seq
    end
  end

  return seq + 1
end

verb event/record_source(listener @ #player, source @ #event<_>)
  let replace_group = event/metadata(source, :replace_group, nothing)
  if replace_group != nothing
    let existing = nothing
    let existing_seq = -1
    for found in event/Delivery(listener, ?event)
      let candidate = found[:event]
      let candidate_source = candidate.event/source
      if event/metadata(candidate_source, :group, nothing) == replace_group && candidate.event/seq > existing_seq
        existing = candidate
        existing_seq = candidate.event/seq
      end
    end

    if existing != nothing
      existing.event/source = source
      existing.event/text = event/render(source, listener)
      return existing
    end
  end

  let seq = event/next_seq(listener)
  let event = #event/log_entry<[listener, seq]>
  let text = event/render(source, listener)

  assert event/Delivery(listener, event)
  event.event/seq = seq
  event.event/text = text
  event.event/source = source

  return event
end

verb event/notify(listener @ #player, text @ #string)
  return event/notify_to(listener, listener, text)
end

verb event/notify_to(listener @ #player, endpoint, text @ #string)
  let source = event/scene(#event/utility, "utility", "event-line utility", "{message}", {:actor -> listener, :message -> text})
  event/record_source(listener, source)
  emit(endpoint, event/render(source, listener))
  return true
end

verb emit_room_event(room @ #room, event @ #event<_>)
  let source = event/scene_at(event, room)
  for found in PresentActor(room, ?listener)
    let listener = found[:listener]
    let text = event/render(source, listener)
    event/record_source(listener, source)
    emit(listener, text)
  end

  return true
end

verb emit_room_event_except(room @ #room, skipped @ #identity, event @ #event<_>)
  let source = event/scene_at(event, room)
  for found in PresentActor(room, ?listener)
    let listener = found[:listener]
    if listener != skipped
      let text = event/render(source, listener)
      event/record_source(listener, source)
      emit(listener, text)
    end
  end

  return true
end

verb event/scene(delegate @ #identity, label @ #string, class @ #string, template @ #string, bindings @ #map)
  return event/with_class(event/with_label(event/narrative(delegate, template, bindings), label), class)
end

verb event/scene_from_template(delegate @ #identity, label @ #string, class @ #string, template, bindings @ #map)
  return event/with_class(event/with_label(event/from_template(delegate, template, bindings), label), class)
end

verb event/scene_at(event @ #event<_>, room @ #room)
  let payload = frob_value(event)
  let bindings = payload[:bindings]
  if bindings == nothing
    bindings = {}
  end
  if bindings[:location] == nothing
    bindings[:location] = room
    payload[:bindings] = bindings
  end
  payload[:location] = room
  return frob(frob_delegate(event), payload)
end

verb look(actor @ #player)
  let room = actor.locatedIn
  let source = event/scene(#event/look, "look", "event-line utility", "{message}", {:actor -> actor, :location -> room, :message -> room.description})
  event/record_source(actor, source)
  emit(actor, event/render(source, actor))

  for found in LocatedIn(?item, room)
    let item = found[:item]
    let text = item.description
    if item != actor && text != nothing
      event/notify(actor, text)
    end
  end

  return true
end

verb examine(actor @ #player, target @ #thing)
  if CanSee(actor, target)
    let source = event/scene(#event/examine, "examine", "event-line utility", "{message}", {:actor -> actor, :target -> target, :message -> target.description})
    event/record_source(actor, source)
    emit(actor, event/render(source, actor))
    return true
  end

  event/notify(actor, "I do not see that.")
  return false
end

verb look_in(actor @ #player, target @ #container)
  if CanSee(actor, target) == false
    event/notify(actor, "I do not see that.")
    return false
  end

  let found_any = false
  for found in LocatedIn(?item, target)
    let item = found[:item]
    let text = item.description
    if text != nothing
      found_any = true
      event/notify(actor, text)
    end
  end

  if found_any == false
    event/notify(actor, "It is empty.")
  end

  return true
end

verb passage/label_for(passage, room)
  let label = one PassageLabel(passage, room, ?label)
  if label == nothing
    label = one PassageAlias(passage, room, ?alias)
  end
  if label == nothing
    label = "somewhere"
  end

  return label
end

verb passage/describe_from(passage, room)
  let description = one PassageDescription(passage, room, ?description)
  if description != nothing
    return description
  end

  return passage/label_for(passage, room)
end

verb go(actor @ #player, direction)
  let room = actor.locatedIn
  let passage_id = nothing
  let destination = nothing
  for found in PassageSide(?passage, room, ?candidate)
    let candidate_passage = found[:passage]
    if passage_id == nothing && PassageAlias(candidate_passage, room, direction) && PassageOpen(candidate_passage, true)
      passage_id = candidate_passage
      destination = found[:candidate]
    end
  end

  if destination == nothing
    event/notify(actor, "You cannot go that way.")
    return false
  end

  let from_label = passage/label_for(passage_id, room)
  let to_label = passage/label_for(passage_id, destination)
  let from_description = passage/describe_from(passage_id, room)
  let to_description = passage/describe_from(passage_id, destination)
  let bindings = {:actor -> actor, :message -> from_label, :passage -> passage_id}
  :emit_room_event(room: room, event: event/scene(#event/movement, "movement", "event-line movement", "{Actor} {go|goes} {message}.", bindings))
  actor.locatedIn = destination
  bindings[:message] = to_label
  :emit_room_event_except(room: destination, skipped: actor, event: event/scene(#event/arrival, "movement", "event-line movement", "{Actor} {arrive|arrives} from {message}.", bindings))
  event/notify(actor, destination.description)
  return true
end

verb builder/can_modify(actor @ #player)
  if Builder(actor) || Delegates(actor, #builder, ?builder_depth)
    return true
  end

  event/notify(actor, "You need builder permission to do that.")
  return false
end

verb builder/current_area(actor @ #player)
  let room = actor.locatedIn
  let area = room.roomInArea
  if area == nothing
    event/notify(actor, "This room is not in an area.")
  end

  return area
end

verb builder/room_value(actor @ #player, name @ #string)
  return frob(#room, [actor, lower(trim(name))])
end

verb builder/passage_value(from @ #room, to @ #room, label @ #string)
  return frob(#passage, [from, to, lower(trim(label))])
end

verb builder/room_named_in_area(area @ #area, name @ #string)
  let wanted = lower(trim(name))
  for found in RoomInArea(?room, area)
    let room = found[:room]
    let room_name = room.name
    if room_name != nothing && lower(room_name) == wanted
      return room
    end
  end

  return nothing
end

verb builder/passage_between(from @ #room, to @ #room)
  for found in PassageSide(?passage, from, to)
    return found[:passage]
  end

  return nothing
end

verb builder/passage_from(from @ #room, command @ #string)
  let direction = lower(trim(command))
  for found in PassageAlias(?passage, from, direction)
    if PassageSide(found[:passage], from, ?destination)
      return found[:passage]
    end
  end

  return nothing
end

verb builder/opposite_direction(direction @ #string)
  let dir = lower(trim(direction))
  if dir == "north" || dir == "n"
    return "south"
  elseif dir == "south" || dir == "s"
    return "north"
  elseif dir == "east" || dir == "e"
    return "west"
  elseif dir == "west" || dir == "w"
    return "east"
  elseif dir == "up" || dir == "u"
    return "down"
  elseif dir == "down" || dir == "d"
    return "up"
  elseif dir == "in" || dir == "i"
    return "out"
  elseif dir == "out" || dir == "o"
    return "in"
  end

  return ""
end

verb build_room(actor @ #player, name @ #string)
  if builder/can_modify(actor) == false
    return false
  end

  let area = builder/current_area(actor)
  if area == nothing
    return false
  end

  let trimmed = trim(name)
  if trimmed == ""
    event/notify(actor, "Build what?")
    return false
  end

  let existing = builder/room_named_in_area(area, trimmed)
  if existing != nothing
    event/notify(actor, "That room already exists in this area.")
    return false
  end

  let room = builder/room_value(actor, trimmed)
  room.name = trimmed
  room.description = string_concat(trimmed, ". An empty room awaiting a description.")
  room.roomInArea = area
  assert command/Noun(room, lower(trimmed))
  assert command/TrustedForName(#player, room)
  assert command/TrustedForGrammar(#player, room)
  event/notify(actor, string_concat("Built ", trimmed, "."))
  return room
end

verb build_room_command(actor @ #player, message @ #string)
  return build_room(actor, message)
end

verb builder/parse_dig(spec @ #string)
  let tokens = words(lower(spec))
  if tokens[0] == nothing || tokens[1] != "to"
    return {:ok -> false}
  end

  let direction = tokens[0]
  let target_words = []
  let index = 2
  while tokens[index] != nothing
    target_words = [@target_words, tokens[index]]
    index = index + 1
  end

  return {:ok -> true, :direction -> direction, :target -> string_join(target_words, " ")}
end

verb create_passage(actor @ #player, from @ #room, to @ #room, label @ #string, return_label)
  if builder/can_modify(actor) == false
    return false
  end

  let from_area = from.roomInArea
  let to_area = to.roomInArea
  if from_area == nothing || to_area == nothing || from_area != to_area
    event/notify(actor, "Passages can only connect rooms in the same area.")
    return false
  end

  let existing = builder/passage_between(from, to)
  if existing != nothing
    event/notify(actor, "Those rooms already have a passage.")
    return false
  end

  let direction = lower(trim(label))
  if direction == ""
    event/notify(actor, "Dig where?")
    return false
  end

  let reverse = ""
  if return_label != nothing
    reverse = lower(trim(return_label))
    if reverse == ""
      reverse = builder/opposite_direction(direction)
    end
  end

  let passage = builder/passage_value(from, to, direction)
  assert PassageInArea(passage, from_area)
  assert PassageSide(passage, from, to)
  assert PassageLabel(passage, from, direction)
  assert PassageAlias(passage, from, direction)
  assert PassageDescription(passage, from, string_concat("A passage leads ", direction, "."))
  assert PassageAmbient(passage, from, true)
  if reverse != ""
    assert PassageSide(passage, to, from)
    assert PassageLabel(passage, to, reverse)
    assert PassageAlias(passage, to, reverse)
    assert PassageDescription(passage, to, string_concat("A passage leads ", reverse, "."))
    assert PassageAmbient(passage, to, false)
  end
  assert PassageOpen(passage, true)
  event/notify(actor, "Passage created.")
  return passage
end

verb create_passage_command(actor @ #player, message @ #string)
  let parsed = builder/parse_dig(message)
  if parsed[:ok] == false
    event/notify(actor, "Usage: dig <direction> to <room name>.")
    return false
  end

  let area = builder/current_area(actor)
  if area == nothing
    return false
  end

  let target = builder/room_named_in_area(area, parsed[:target])
  if target == nothing
    event/notify(actor, "No room by that name exists in this area.")
    return false
  end

  return create_passage(actor, actor.locatedIn, target, parsed[:direction], "")
end

verb remove_passage(actor @ #player, passage)
  if builder/can_modify(actor) == false
    return false
  end

  retract PassageInArea(passage, _)
  retract PassageSide(passage, _, _)
  retract PassageLabel(passage, _, _)
  retract PassageAlias(passage, _, _)
  retract PassageDescription(passage, _, _)
  retract PassageAmbient(passage, _, _)
  retract PassageOpen(passage, _)
  event/notify(actor, "Passage removed.")
  return true
end

verb remove_passage_command(actor @ #player, message @ #string)
  let passage = builder/passage_from(actor.locatedIn, message)
  if passage == nothing
    event/notify(actor, "No passage matches that direction.")
    return false
  end

  return remove_passage(actor, passage)
end

verb set_passage_description(actor @ #player, passage, room @ #room, description @ #string, ambient)
  if builder/can_modify(actor) == false
    return false
  end

  if PassageSide(passage, room, ?destination) == false
    event/notify(actor, "That passage is not connected to this room.")
    return false
  end

  retract PassageDescription(passage, room, _)
  retract PassageAmbient(passage, room, _)
  assert PassageDescription(passage, room, description)
  assert PassageAmbient(passage, room, ambient)
  event/notify(actor, "Passage description updated.")
  return true
end

verb set_passage_side(actor @ #player, passage, room @ #room, label @ #string, description @ #string, ambient)
  if builder/can_modify(actor) == false
    return false
  end

  if PassageSide(passage, room, ?destination) == false
    event/notify(actor, "That passage is not connected to this room.")
    return false
  end

  let direction = lower(trim(label))
  if direction == ""
    event/notify(actor, "Direction is required.")
    return false
  end

  retract PassageLabel(passage, room, _)
  retract PassageAlias(passage, room, _)
  retract PassageDescription(passage, room, _)
  retract PassageAmbient(passage, room, _)
  assert PassageLabel(passage, room, direction)
  assert PassageAlias(passage, room, direction)
  assert PassageDescription(passage, room, description)
  assert PassageAmbient(passage, room, ambient)
  event/notify(actor, "Passage updated.")
  return true
end

verb builder/parse_describe_exit(spec @ #string)
  let lowered = lower(spec)
  let tokens = words(lowered)
  if tokens[0] == nothing || tokens[1] == nothing
    return {:ok -> false}
  end

  let direction = tokens[0]
  let offset = string_len(direction)
  let description = trim(string_slice(spec, offset, string_len(spec)))
  return {:ok -> description != "", :direction -> direction, :description -> description}
end

verb set_passage_description_command(actor @ #player, message @ #string)
  let parsed = builder/parse_describe_exit(message)
  if parsed[:ok] == false
    event/notify(actor, "Usage: describe-exit <direction> <description>.")
    return false
  end

  let passage = builder/passage_from(actor.locatedIn, parsed[:direction])
  if passage == nothing
    event/notify(actor, "No passage matches that direction.")
    return false
  end

  return set_passage_description(actor, passage, actor.locatedIn, parsed[:description], true)
end

verb get(actor @ #player, item @ #thing)
  if Carrying(actor, item)
    event/notify(actor, "You already have that.")
    return false
  end

  if Portable(item) && CanSee(actor, item)
    let room = actor.locatedIn
    item.locatedIn = actor
    :emit_room_event(room: room, event: event/scene(#event/take, "transfer", "event-line transfer", "{Actor} {take|takes} {the item}.", {:actor -> actor, :item -> item}))
    return true
  end

  event/notify(actor, "You cannot take that.")
  return false
end

verb get_from(actor @ #player, item @ #thing, container @ #container)
  if Carrying(actor, item)
    event/notify(actor, "You already have that.")
    return false
  end

  if CanSee(actor, container) == false
    event/notify(actor, "I do not see that.")
    return false
  end

  if LocatedIn(item, container) && Portable(item)
    let room = actor.locatedIn
    item.locatedIn = actor
    :emit_room_event(room: room, event: event/scene(#event/take_from, "transfer", "event-line transfer", "{Actor} {take|takes} {the item} from {the container}.", {:actor -> actor, :item -> item, :container -> container}))
    return true
  end

  event/notify(actor, "That is not in there.")
  return false
end

verb drop(actor @ #player, item @ #thing)
  let room = actor.locatedIn

  if Carrying(actor, item)
    item.locatedIn = room
    :emit_room_event(room: room, event: event/scene(#event/drop, "transfer", "event-line transfer", "{Actor} {drop|drops} {the item}.", {:actor -> actor, :item -> item}))
    return true
  end

  event/notify(actor, "You are not carrying that.")
  return false
end

verb put(actor @ #player, item @ #thing, container @ #container)
  if Carrying(actor, item) && CanSee(actor, container)
    let room = actor.locatedIn
    item.locatedIn = container
    :emit_room_event(room: room, event: event/scene(#event/put, "transfer", "event-line transfer", "{Actor} {put|puts} {the item} in {the container}.", {:actor -> actor, :item -> item, :container -> container}))
    return true
  end

  event/notify(actor, "You are not carrying that.")
  return false
end

verb push(actor @ #player, target @ #thing)
  if target != #red_button || CanSee(actor, target) == false
    event/notify(actor, "That does not seem pushable.")
    return false
  end

  if ButtonArmed(target)
    event/notify(actor, "The red button is already humming.")
    return false
  end

  let room = actor.locatedIn
  assert ButtonArmed(target)
  event/notify(actor, "You press the red button. It clicks, then begins to hum.")
  let task = spawn :button_resolves(actor: actor, target: target, room: room) after 0.25
  return task != nothing
end

verb button_resolves(actor @ #player, target @ #thing, room @ #room)
  if ButtonArmed(target) == false
    return false
  end

  retract ButtonArmed(target)
  :emit_room_event(room: room, event: event/scene(#event/button, "alert", "event-line alert", "The red button gives one final cheerful ding.", {:target -> target}))
  return true
end

verb say(actor @ #player, message)
  let room = actor.locatedIn
  let event = event/with_presentation(event/scene(#event/say, "speech", "event-line speech", "{Actor} {say|says}, \"{message}\"", {:actor -> actor, :message -> message}), :speech)
  :emit_room_event(room: room, event: event)
  return true
end

verb emote(actor @ #player, message)
  let room = actor.locatedIn
  let template = template/from_parts([template/name(:emote_actor, true), " ", message])
  let event = event/with_presentation(event/scene_from_template(#event/emote, "emote", "event-line social", template, {:actor -> actor, :emote_actor -> actor.name}), :social)
  :emit_room_event(room: room, event: event)
  return true
end

verb social_event(actor @ #player, template @ #string, bindings @ #map)
  return event/with_presentation(event/scene(#event/social, "social", "event-line social", template, bindings), :social)
end

verb social_emit(actor @ #player, template @ #string, bindings @ #map)
  :emit_room_event(room: actor.locatedIn, event: social_event(actor, template, bindings))
  return true
end

verb social_directed_event(actor @ #player, target @ #thing, prep @ #string, verb_self @ #string, verb_other @ #string)
  return social_event(actor, string_concat("{Actor} {", verb_self, "|", verb_other, "} ", prep, " {the iobj}."), {:actor -> actor, :iobj -> target})
end

verb nod(actor @ #player)
  return social_emit(actor, "{Actor} {nod|nods}.", {:actor -> actor})
end

verb nod_at(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "at", "nod", "nods"))
  return true
end

verb nod_to(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "to", "nod", "nods"))
  return true
end

verb wave(actor @ #player)
  return social_emit(actor, "{Actor} {wave|waves}.", {:actor -> actor})
end

verb wave_at(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "at", "wave", "waves"))
  return true
end

verb wave_to(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "to", "wave", "waves"))
  return true
end

verb bow(actor @ #player)
  return social_emit(actor, "{Actor} {bow|bows}.", {:actor -> actor})
end

verb bow_at(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "at", "bow", "bows"))
  return true
end

verb bow_to(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "to", "bow", "bows"))
  return true
end

verb bonk(actor @ #player, target @ #thing)
  if target == actor
    return social_emit(actor, "{Actor} {bonk|bonks} {r}.", {:actor -> actor})
  end

  return social_emit(actor, "{Actor} {bonk|bonks} {the target}.", {:actor -> actor, :target -> target})
end

verb oif(actor @ #player)
  return say(actor, "Oif!")
end

verb smile(actor @ #player)
  return social_emit(actor, "{Actor} {smile|smiles}.", {:actor -> actor})
end

verb smile_at(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "at", "smile", "smiles"))
  return true
end

verb smile_to(actor @ #player, target @ #thing)
  :emit_room_event(room: actor.locatedIn, event: social_directed_event(actor, target, "to", "smile", "smiles"))
  return true
end

verb frown(actor @ #player)
  return social_emit(actor, "{Actor} {frown|frowns}.", {:actor -> actor})
end

verb laugh(actor @ #player)
  return social_emit(actor, "{Actor} {laugh|laughs}.", {:actor -> actor})
end

verb dance(actor @ #player)
  return social_emit(actor, "{Actor} {dance|dances}.", {:actor -> actor})
end

verb shrug(actor @ #player)
  return social_emit(actor, "{Actor} {shrug|shrugs} {p} shoulders.", {:actor -> actor})
end

verb think(actor @ #player, message)
  return social_emit(actor, "{Actor} . o O ( {message} )", {:actor -> actor, :message -> message})
end

verb ponder(actor @ #player)
  return social_emit(actor, "{Actor} {ponder|ponders}.", {:actor -> actor})
end

verb clap(actor @ #player)
  return social_emit(actor, "{Actor} {clap|claps} {p} hands.", {:actor -> actor})
