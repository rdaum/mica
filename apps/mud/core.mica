// Small relational world core for daemon/telnet demos.
//
// This file intentionally keeps the world model in ordinary Mica relations:
// rooms, exits, containment, visibility, names, descriptions, and command verbs
// are all authorable world state rather than privileged runtime concepts.

make_identity(:player)
make_identity(:programmer)
make_identity(:builder)
make_identity(:thing)
make_identity(:portable)
make_identity(:container)
make_identity(:room)
make_identity(:area)
make_identity(:passage)
make_identity(:event/movement)
make_identity(:event/arrival)
make_identity(:event/take)
make_identity(:event/take_from)
make_identity(:event/drop)
make_identity(:event/put)
make_identity(:event/say)
make_identity(:event/emote)
make_identity(:event/social)
make_identity(:event/look)
make_identity(:event/examine)
make_identity(:event/utility)
make_identity(:event/button)
make_identity(:event/log_entry)

make_identity(:alice)
make_identity(:coin)
make_identity(:box)
make_identity(:red_button)
make_identity(:first_room)
make_identity(:north_room)
make_identity(:attic)
make_identity(:hotel_area)
make_identity(:bob)

make_identity(:command/pattern/look_room)
make_identity(:command/pattern/look_target)
make_identity(:command/pattern/look_inside)
make_identity(:command/pattern/message_command)
make_identity(:command/pattern/get)
make_identity(:command/pattern/get_from)
make_identity(:command/pattern/drop)
make_identity(:command/pattern/put)
make_identity(:command/pattern/push)
make_identity(:command/pattern/say)
make_identity(:command/pattern/emote)
make_identity(:command/pattern/social_target)
make_identity(:command/pattern/social_at)
make_identity(:command/pattern/social_to)
make_identity(:command/pattern/social_none)
make_identity(:command/pattern/think)

make_relation(:Delegates, 3)

make_relation(:Portable, 1)
make_functional_relation(:Name, 2, [0])
make_functional_relation(:Description, 2, [0])
make_functional_relation(:LocatedIn, 2, [0])
make_functional_relation(:RoomInArea, 2, [0])
make_relation(:ProperNoun, 1)
make_relation(:Plural, 1)
make_functional_relation(:PronounSubject, 2, [0])
make_functional_relation(:PronounObject, 2, [0])
make_functional_relation(:PronounPossessiveAdjective, 2, [0])
make_functional_relation(:PronounPossessiveNoun, 2, [0])
make_functional_relation(:PronounReflexive, 2, [0])

make_relation(:PassageInArea, 2)
make_relation(:PassageSide, 3)
make_functional_relation(:PassageLabel, 3, [0, 1])
make_relation(:PassageAlias, 3)
make_functional_relation(:PassageDescription, 3, [0, 1])
make_functional_relation(:PassageAmbient, 3, [0, 1])
make_functional_relation(:PassageOpen, 2, [0])
make_relation(:Exit, 3)
make_relation(:ReachableRoom, 3)
make_relation(:Builder, 1)

// Recursive containment/location views.
make_relation(:Within, 2)
make_relation(:Contents, 2)
make_relation(:Carrying, 2)
make_relation(:CanSee, 2)
make_relation(:PresentActor, 2)
make_relation(:ButtonArmed, 1)

// Parser-facing state is separate from display state. A thing can be visible
// without being allowed to pollute the command parser.
make_relation(:command/VerbAlias, 2)
make_relation(:command/PrefixShortcut, 2)
make_relation(:command/Form, 1)
make_relation(:command/Pattern, 3)
make_relation(:command/PatternPart, 4)
make_relation(:command/Role, 3)
make_relation(:command/Preposition, 2)
make_functional_relation(:command/MissingArgumentMessage, 2, [0])
make_relation(:command/Noun, 2)
make_relation(:command/NounAlias, 2)
make_relation(:command/Name, 2)
make_relation(:VisibleTo, 2)
make_relation(:event/Delivery, 2)
make_functional_relation(:event/Seq, 2, [0])
make_functional_relation(:event/Text, 2, [0])
make_functional_relation(:event/Source, 2, [0])
make_relation(:command/TrustedForName, 2)
make_relation(:command/NameMatchable, 2)
make_relation(:command/TrustedForGrammar, 2)
make_relation(:command/GrammarSource, 2)
make_relation(:command/HandlerScope, 2)

make_relation(:CanRead, 2)
make_relation(:CanWrite, 2)
make_relation(:CanInvoke, 2)
make_relation(:CanEffect, 1)
make_relation(:RoleCanRead, 2)
make_relation(:RoleCanWrite, 2)
make_relation(:RoleCanInvoke, 2)
make_relation(:RoleCanEffect, 1)

assert Delegates(#portable, #thing, 0)
assert Delegates(#container, #thing, 0)
assert Delegates(#player, #thing, 0)
assert Delegates(#alice, #programmer, 0)
assert Delegates(#alice, #builder, 0)
assert Delegates(#event/movement, #event, 0)
assert Delegates(#event/arrival, #event, 0)
assert Delegates(#event/take, #event, 0)
assert Delegates(#event/take_from, #event, 0)
assert Delegates(#event/drop, #event, 0)
assert Delegates(#event/put, #event, 0)
assert Delegates(#event/say, #event, 0)
assert Delegates(#event/emote, #event, 0)
assert Delegates(#event/social, #event, 0)
assert Delegates(#event/look, #event, 0)
assert Delegates(#event/examine, #event, 0)
assert Delegates(#event/utility, #event, 0)
assert Delegates(#event/button, #event, 0)
assert Delegates(#event/log_entry, #event, 0)
assert Delegates(#coin, #portable, 0)
assert Delegates(#alice, #player, 0)
assert Delegates(#bob, #player, 0)
assert Delegates(#box, #container, 0)
assert Delegates(#red_button, #thing, 0)
assert Delegates(#first_room, #room, 0)
assert Delegates(#north_room, #room, 0)
assert Delegates(#attic, #room, 0)
assert Delegates(#hotel_area, #area, 0)

assert Portable(#coin)

#alice.name = "Alice"
#bob.name = "Bob"
#coin.name = "coin"
#box.name = "box"
#red_button.name = "button"
#first_room.name = "First Room"
#north_room.name = "North Room"
#attic.name = "Dusty Attic"
#hotel_area.name = "Timbran Hotel"
assert ProperNoun(#alice)
assert ProperNoun(#bob)
assert PronounSubject(#alice, "she")
assert PronounObject(#alice, "her")
assert PronounPossessiveAdjective(#alice, "her")
assert PronounPossessiveNoun(#alice, "hers")
assert PronounReflexive(#alice, "herself")
assert PronounSubject(#bob, "he")
assert PronounObject(#bob, "him")
assert PronounPossessiveAdjective(#bob, "his")
assert PronounPossessiveNoun(#bob, "his")
assert PronounReflexive(#bob, "himself")

#alice.description = "Alice is alert and ready to test the room's stranger affordances."
#coin.description = "A tarnished brass coin catches the light."
#bob.description = "Bob is here, looking faintly puzzled."
#box.description = "A small wooden box rests here, open and empty."
#red_button.description = "A red button protrudes from the wall under a brass sign reading DO NOT PRESS."
#first_room.description = "First Room. You are standing in a plain stone room."
#north_room.description = "North Room. It is quieter here, and the ceiling slopes upward."
#attic.description = "Dusty Attic. Old beams vanish into shadow."
#hotel_area.description = "A development and demonstration area for the Timbran Hotel."

#alice.locatedIn = #first_room
#bob.locatedIn = #first_room
#coin.locatedIn = #first_room
#box.locatedIn = #first_room
#red_button.locatedIn = #first_room

#first_room.roomInArea = #hotel_area
#north_room.roomInArea = #hotel_area
#attic.roomInArea = #hotel_area

assert Builder(#alice)

assert PassageInArea(#passage<[#first_room, #north_room, "north"]>, #hotel_area)
assert PassageSide(#passage<[#first_room, #north_room, "north"]>, #first_room, #north_room)
assert PassageSide(#passage<[#first_room, #north_room, "north"]>, #north_room, #first_room)
assert PassageLabel(#passage<[#first_room, #north_room, "north"]>, #first_room, "north")
assert PassageLabel(#passage<[#first_room, #north_room, "north"]>, #north_room, "south")
assert PassageAlias(#passage<[#first_room, #north_room, "north"]>, #first_room, "north")
assert PassageAlias(#passage<[#first_room, #north_room, "north"]>, #first_room, "n")
assert PassageAlias(#passage<[#first_room, #north_room, "north"]>, #north_room, "south")
assert PassageAlias(#passage<[#first_room, #north_room, "north"]>, #north_room, "s")
assert PassageDescription(#passage<[#first_room, #north_room, "north"]>, #first_room, "A northern archway leads deeper into the hotel.")
assert PassageDescription(#passage<[#first_room, #north_room, "north"]>, #north_room, "The way south returns to the first room.")
assert PassageAmbient(#passage<[#first_room, #north_room, "north"]>, #first_room, true)
assert PassageAmbient(#passage<[#first_room, #north_room, "north"]>, #north_room, false)
assert PassageOpen(#passage<[#first_room, #north_room, "north"]>, true)

assert PassageInArea(#passage<[#north_room, #attic, "up"]>, #hotel_area)
assert PassageSide(#passage<[#north_room, #attic, "up"]>, #north_room, #attic)
assert PassageSide(#passage<[#north_room, #attic, "up"]>, #attic, #north_room)
assert PassageLabel(#passage<[#north_room, #attic, "up"]>, #north_room, "up")
assert PassageLabel(#passage<[#north_room, #attic, "up"]>, #attic, "down")
assert PassageAlias(#passage<[#north_room, #attic, "up"]>, #north_room, "up")
assert PassageAlias(#passage<[#north_room, #attic, "up"]>, #north_room, "u")
assert PassageAlias(#passage<[#north_room, #attic, "up"]>, #attic, "down")
assert PassageAlias(#passage<[#north_room, #attic, "up"]>, #attic, "d")
assert PassageDescription(#passage<[#north_room, #attic, "up"]>, #north_room, "A narrow stair climbs into the attic.")
assert PassageDescription(#passage<[#north_room, #attic, "up"]>, #attic, "The stair descends to the north room.")
assert PassageAmbient(#passage<[#north_room, #attic, "up"]>, #north_room, true)
assert PassageAmbient(#passage<[#north_room, #attic, "up"]>, #attic, false)
assert PassageOpen(#passage<[#north_room, #attic, "up"]>, true)

