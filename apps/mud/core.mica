assert command/PatternPart(#command/pattern/put, 2, :object_role, :container)

assert command/Pattern(:push, :push, #command/pattern/push)
assert command/PatternPart(#command/pattern/push, 0, :object_role, :target)

assert command/Pattern(:say, :say, #command/pattern/say)
