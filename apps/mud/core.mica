assert command/Pattern(:get, :get, #command/pattern/get)
assert command/PatternPart(#command/pattern/get, 0, :object_role, :item)

assert command/Pattern(:get, :get_from, #command/pattern/get_from)
assert command/PatternPart(#command/pattern/get_from, 0, :object_role, :item)
assert command/PatternPart(#command/pattern/get_from, 1, :prep, :from)
assert command/PatternPart(#command/pattern/get_from, 2, :object_role, :container)

assert command/Pattern(:drop, :drop, #command/pattern/drop)
assert command/PatternPart(#command/pattern/drop, 0, :object_role, :item)

assert command/Pattern(:put, :put, #command/pattern/put)
