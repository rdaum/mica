verb ui/actor_name(obj)
  if frob_delegate(obj) == #passage
    let current = ui/current_actor()
    if current != nothing
      return ui/passage_name(current, obj)
    end
    return "passage"
  end

  let name = obj.name
  if name == nothing
    return to_literal(obj)
  end

  return name
end

verb ui/direction_text(direction)
  if direction == nothing
    return ""
  end

  if direction == "north"
    return "north"
  elseif direction == "south"
    return "south"
  elseif direction == "up"
    return "up"
  elseif direction == "down"
    return "down"
  end

  if direction == :north
    return "north"
  elseif direction == :south
    return "south"
  elseif direction == :up
    return "up"
  elseif direction == :down
    return "down"
  end

  return direction
end

verb ui/can_build(actor @ #player)
  return Builder(actor) || Delegates(actor, #builder, ?builder_depth)
end

verb ui/current_actor()
  let current = actor()
  if current != nothing && Delegates(current, #player, 0)
    return current
  end

  return nothing
end

verb ui/ensure_actor_location(actor @ #player)
  let room = actor.locatedIn
  if room == nothing
    actor.locatedIn = #first_room
    return #first_room
  end

  return room
end

verb ui/entity_from_literal(text)
  if text == nothing
    return nothing
  end

  return from_literal(text)
end

verb ui/passage_visible_from(actor @ #player, passage)
  let room = actor.locatedIn
  if room == nothing
    return false
  end

  return PassageSide(passage, room, ?destination)
end

verb ui/passage_room_for(actor @ #player, passage)
  let room = actor.locatedIn
  if room != nothing && PassageSide(passage, room, ?destination)
    return room
  end

  return nothing
end

verb ui/passage_name(actor @ #player, passage)
  let room = ui/passage_room_for(actor, passage)
  if room == nothing
    return "passage"
  end

  return passage/label_for(passage, room)
end

verb ui/description_text(actor @ #player, entity)
  if frob_delegate(entity) == #passage
    let room = ui/passage_room_for(actor, entity)
    if room == nothing
      return ""
    end
    return passage/describe_from(entity, room)
  end

  return entity.description
end

verb ui/can_inspect_entity(actor @ #player, entity)
  if entity == nothing
    return false
  end

  if CanSee(actor, entity)
    return true
  end

  if ui/can_build(actor) && Delegates(entity, #room, 0) && entity.roomInArea == builder/current_area(actor)
    return true
  end

  return frob_delegate(entity) == #passage && ui/passage_visible_from(actor, entity)
end

verb ui/can_program(actor @ #player)
  return Delegates(actor, #programmer, 0)
end

verb ui/status_revision()
  let current = ui/current_actor()
  if current == nothing
    return 0
  end

  let revision = 1
  for found in event/Delivery(current, ?event)
    let seq = found[:event].event/seq
    if seq > revision || seq == revision
      revision = seq + 1
    end
  end
  revision = revision * 2

  let ui_revision = endpoint().session/revision
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end

  return revision
end

verb ui/bump_revision(endpoint)
  let current = ui/current_actor()
  let revision = 1
  if current != nothing
    for found in event/Delivery(current, ?event)
      let seq = found[:event].event/seq
      if seq > revision || seq == revision
        revision = seq + 1
      end
    end
  end

  revision = revision * 2

  let ui_revision = endpoint.session/revision
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end
  revision = revision + 1

  endpoint.session/revision = revision
  return revision
end

verb sync_view_revision(view)
  if ui/View(view) == false
    return 0
  end

  return ui/status_revision()
end

verb sync_view_tree(view, revision)
  let current = ui/current_actor()
  if ui/View(view) == false || current == nothing
    return ui/auth_required_node()
  end
  ui/ensure_actor_location(current)

  let limit = endpoint().session/narrativeLimit
  if limit == nothing
    limit = 40
  end
  return ui/world_view_node(current, revision, limit)
end
