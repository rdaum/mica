// Server-owned UI session state and sync action selectors for the MUD app.

make_relation(:ui/View, 1)
make_functional_relation(:ui/SyncAction, 2, [0])
make_functional_relation(:session/Actor, 2, [0])
make_functional_relation(:session/Inspect, 2, [0])
make_functional_relation(:session/InspectPulse, 2, [0])
make_functional_relation(:session/NarrativeLimit, 2, [0])
make_functional_relation(:session/Revision, 2, [0])
make_functional_relation(:session/CommandDraft, 2, [0])

make_identity(:ui/sync_action)
make_identity(:ui/inspect_action)
make_identity(:ui/command_action)
make_identity(:ui/load_older_events_action)
make_identity(:ui/build_room_action)
make_identity(:ui/create_passage_action)
make_identity(:ui/describe_passage_action)

assert ui/View(21)
assert Delegates(#ui/inspect_action, #ui/sync_action, 0)
assert Delegates(#ui/command_action, #ui/sync_action, 0)
assert Delegates(#ui/load_older_events_action, #ui/sync_action, 0)
assert Delegates(#ui/build_room_action, #ui/sync_action, 0)
assert Delegates(#ui/create_passage_action, #ui/sync_action, 0)
assert Delegates(#ui/describe_passage_action, #ui/sync_action, 0)
"mud_inspect".ui/syncAction = #ui/inspect_action
"mud_command".ui/syncAction = #ui/command_action
"mud_load_older_events".ui/syncAction = #ui/load_older_events_action
"mud_build_room".ui/syncAction = #ui/build_room_action
"mud_create_passage".ui/syncAction = #ui/create_passage_action
"mud_describe_passage".ui/syncAction = #ui/describe_passage_action

grant #web
  read:
    :ui/View
    :ui/SyncAction
    :session/Actor
    :session/Inspect
    :session/InspectPulse
    :session/NarrativeLimit
    :session/Revision
    :session/CommandDraft
    :Delegates
    :Name
    :event/Delivery
    :event/Seq
    :event/Source
  write:
    :event/Delivery
    :event/Seq
    :event/Text
    :event/Source
    :session/Actor
    :session/Inspect
    :session/InspectPulse
    :session/NarrativeLimit
    :session/Revision
    :session/CommandDraft
  invoke:
    :sync_event
    :sync_view_revision
    :sync_view_tree
    :ui/auth_required_node
    :ui/status_revision
    :ui/current_actor
    :ui/entity_from_literal
    :ui/actor_name
    :event/next_seq
    :event/record_source
    :actor
    :string_concat
    :lower
    :trim
end

CanRead(#web, relation) :-
  RoleCanRead(#player, relation)

CanWrite(#web, relation) :-
  RoleCanWrite(#player, relation)

CanInvoke(#web, selector) :-
  RoleCanInvoke(#player, selector)

CanEffect(#web) :-
  RoleCanEffect(#player)

grant role #player
  read:
    :session/Inspect
    :session/InspectPulse
    :event/Source
