assert CanRead(#web, :ui/View)
assert CanRead(#web, :ui/SyncAction)
assert CanRead(#web, :session/Actor)
assert CanRead(#web, :session/Inspect)
assert CanRead(#web, :session/NarrativeLimit)
assert CanRead(#web, :session/Revision)
assert CanRead(#web, :session/CanAssumeActor)
assert CanRead(#web, :Delegates)
assert CanRead(#web, :Name)
assert CanRead(#web, :event/Delivery)
