verb ui/actor_name(obj)
  let name = one Name(obj, ?name)
  if name == nothing
    return to_literal(obj)
  end

  return name
end

verb ui/direction_text(direction)
  if direction == :north
    return "north"
  elseif direction == :south
    return "south"
  elseif direction == :up
    return "up"
  elseif direction == :down
    return "down"
  end

  return to_literal(direction)
end

verb ui/current_actor()
  return one session/Actor(endpoint(), ?actor)
end

verb ui/entity_from_literal(text)
  if text == nothing
    return nothing
  end

  return from_literal(text)
end

verb ui/can_program(actor @ #player)
  return Delegates(actor, #programmer, 0)
end

verb ui/status_revision()
  let current = ui/current_actor()
  if current == nothing
    return 0
  end

  let revision = 1
  for found in event/Delivery(current, ?event)
    let seq = one event/Seq(found[:event], ?seq)
    if seq > revision || seq == revision
      revision = seq + 1
    end
  end
  let ui_revision = one session/Revision(endpoint(), ?stored_ui_revision)
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end

  return revision
end

verb ui/bump_revision(endpoint)
  let current = ui/current_actor()
  let revision = 1
  if current != nothing
    for found in event/Delivery(current, ?event)
      let seq = one event/Seq(found[:event], ?seq)
      if seq > revision || seq == revision
        revision = seq + 1
      end
    end
  end

  let ui_revision = one session/Revision(endpoint, ?stored_ui_revision)
  if ui_revision != nothing && ui_revision > revision
    revision = ui_revision
  end
  revision = revision + 2

  retract session/Revision(endpoint, _)
  assert session/Revision(endpoint, revision)
  return revision
end

verb ui/login_actor(name)
  let normalized = lower(trim(name))
  if normalized == "alice"
    return #alice
  elseif normalized == "bob"
    return #bob
  end

  return nothing
end

verb sync_view_revision(view)
  if ui/View(view) == false
    return 0
  end

  return ui/status_revision()
end

verb sync_view_tree(view, revision)
  let current = ui/current_actor()
  if ui/View(view) == false || current == nothing
    return ui/login_view_node()
  end

  let limit = one session/NarrativeLimit(endpoint(), ?limit)
  if limit == nothing
    limit = 40
  end
  return ui/world_view_node(current, revision, limit)
end
