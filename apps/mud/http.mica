// HTTP document route for the DOM-synced MUD app.

assert CanInvoke(#web, :http_request)
assert CanRead(#web, :mud/RuntimeConfig)
assert CanInvoke(#web, :http/document)
assert CanInvoke(#web, :http_login_icon_node)
assert CanInvoke(#web, :http_login_icon_label_node)
assert CanInvoke(#web, :http_login_document)
assert CanInvoke(#web, :http_login_style)
assert CanInvoke(#web, :http/base_style)
assert CanInvoke(#web, :http/login_style)
assert CanInvoke(#web, :http/presence_style)
assert CanInvoke(#web, :http/narrative_style)
assert CanInvoke(#web, :http/bootstrap_script)
assert CanInvoke(#web, :dom_text)
assert CanInvoke(#web, :dom_element)
assert CanInvoke(#web, :dom_raw)
assert CanInvoke(#web, :to_xml)
assert CanInvoke(#web, :string_contains)
assert CanInvoke(#web, :string_len)
assert CanInvoke(#web, :string_slice)
assert CanInvoke(#web, :string_starts_with)

verb http_login_icon_node(name)
  name == "login" && return dom <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><path d="m10 17 5-5-5-5"></path><path d="M15 12H3"></path></svg>
  name == "plus" && return dom <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
  name == "user-plus" && return dom <svg class="login-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M19 8v6"></path><path d="M22 11h-6"></path></svg>

  return dom <span class="login-icon-fallback"></span>
end

verb http_login_icon_label_node(icon, label)
  return dom <span class="login-icon-label">{http_login_icon_node(icon)}<span>{label}</span></span>
end

verb http_request(request)
  let http_method = one RequestMethod(request, ?m)
  let path = one RequestPath(request, ?path)

  if http_method == "GET" && (path == "/auth/login" || string_starts_with(path, "/auth/login?"))
    return http_html(200, http_login_document(path))
  end

  if http_method == "GET" && (path == "/" || path == "/mud" || string_starts_with(path, "/mud?"))
    return http_html(200, http/document(21))
  end

  return http_text(404, "not found")
end

verb http_login_document(path)
  let create_mode = string_contains(path, "mode=create")
  let start_url = "/auth/start/github?return=%2Fmud"
  if string_starts_with(path, "/auth/login?")
    start_url = string_concat("/auth/start/github", string_slice(path, string_len("/auth/login"), string_len(path)))
  end

  let sign_in_class = "auth-tab"
  let create_class = "auth-tab"
  let github_label = "Sign in with GitHub"
  let github_icon = "login"
  let divider_label = "or continue with player name"
  if create_mode == true
    create_class = "auth-tab active"
    github_label = "Connect with GitHub"
    github_icon = "plus"
    divider_label = "or create with player name"
  else
    sign_in_class = "auth-tab active"
  end

  let github_actions = []
  if #mud/config_github_auth.mud/runtimeConfig == true
    github_actions = [dom <a class="github-signin" href={start_url}>
      <span class="github-mark" aria-hidden="true">GH</span>
      {http_login_icon_label_node(github_icon, github_label)}
    </a>]
  end

  let local_forms = []
  if #mud/config_local_password_auth.mud/runtimeConfig == true
    if create_mode == true
      local_forms = [dom <form class="local-signin" method="post" action="/auth/create">
        <input type="hidden" name="return" value="/mud" />
        <label><span>Player Name</span><input name="login" autocomplete="username" placeholder="Enter your new player name" required="required" /></label>
        <label><span>Password</span><input name="password" type="password" autocomplete="new-password" placeholder="Choose a password" required="required" /></label>
        <label><span>Confirm Password</span><input name="confirm_password" type="password" autocomplete="new-password" placeholder="Re-enter your password" required="required" /></label>
        <button type="submit">{http_login_icon_label_node("user-plus", "Create Player")}</button>
      </form>]
    else
      local_forms = [dom <form class="local-signin" method="post" action="/auth/login">
        <input type="hidden" name="return" value="/mud" />
        <label><span>Player Name</span><input name="login" autocomplete="username" placeholder="Enter your player name" required="required" /></label>
        <label><span>Password</span><input name="password" type="password" autocomplete="current-password" placeholder="Enter your password" required="required" /></label>
        <button type="submit">{http_login_icon_label_node("login", "Sign In")}</button>
      </form>]
    end
  end

  let empty_state = []
  if #mud/config_github_auth.mud/runtimeConfig != true && #mud/config_local_password_auth.mud/runtimeConfig != true
    empty_state = [dom <p class="empty">No sign-in method is enabled for this MUD.</p>]
  end

  let head = dom <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in to Mica MUD</title>
    <style>{dom_raw(http_login_style())}</style>
  </head>
  let body = dom <body>
    <main class="login-shell">
      <section class="hero-panel">
        <div class="hero-copy">
          <p class="eyebrow">Mica MUD</p>
          <h1>Enter the Mica Rooms</h1>
          <p class="summary">Connect an existing player or create one for this world.</p>
        </div>
      </section>
      <section class="login-panel">
        <nav class="auth-tabs" aria-label="Authentication mode">
          <a class={sign_in_class} href="/auth/login?return=%2Fmud">{http_login_icon_label_node("login", "Sign In")}</a>
          <a class={create_class} href="/auth/login?return=%2Fmud&amp;mode=create">{http_login_icon_label_node("user-plus", "Create Player")}</a>
        </nav>
        {@github_actions}
        <div class="auth-divider"><span>{divider_label}</span></div>
        {@local_forms}
        {@empty_state}
      </section>
    </main>
  </body>
  return to_xml([dom_raw("<!doctype html>"), dom <html lang="en">{head}{body}</html>])
end

verb http_login_style()
  return "html,body{margin:0;min-height:100%;font-family:Arial,Helvetica,Nimbus Sans,Liberation Sans,sans-serif;color:#f8fafc;background:#151515}body{min-height:100vh}.login-shell{min-height:100vh;display:grid;align-content:start;justify-items:center;gap:28px;padding:30px 22px 44px;background:#555}.hero-panel{width:min(100%,660px);min-height:360px;box-sizing:border-box;display:grid;align-items:end;border:1px solid #343849;background:linear-gradient(180deg,rgba(17,24,39,.10),rgba(17,24,39,.86)),linear-gradient(135deg,#2c221c,#5f493a 48%,#1f2937);padding:34px;box-shadow:0 0 0 16px #1d1c24,0 0 0 32px #2f2f31}.hero-copy{max-width:540px}.login-panel{width:min(100%,480px);box-sizing:border-box;padding-top:8px}.eyebrow{margin:0 0 12px;color:#7dd3fc;font-size:12px;font-weight:700;text-transform:uppercase}h1{margin:0;color:#fff;font-size:30px;line-height:1.1;font-weight:800}.summary{margin:12px 0 0;color:#e5e7eb;font-size:15px;line-height:1.5}.auth-tabs{display:grid;grid-template-columns:1fr 1fr;margin-bottom:24px;border-bottom:1px solid rgba(17,24,39,.35)}.auth-tab{display:flex;align-items:center;justify-content:center;min-height:44px;color:#e5e7eb;text-decoration:none;font-size:15px;font-weight:700;border-bottom:3px solid transparent}.auth-tab.active{color:#6d86ff;border-bottom-color:#6d86ff}.login-icon{flex:0 0 auto;width:1rem;height:1rem;stroke-width:2}.login-icon-label{display:inline-flex;align-items:center;justify-content:center;gap:8px;min-width:0}.login-icon-label>span:last-child{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.login-icon-fallback{display:inline-block;width:1rem;height:1rem}.github-signin,.local-signin button{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;min-height:60px;box-sizing:border-box;border:0;border-radius:8px;background:#5b6df6;color:#fff;text-decoration:none;font-size:16px;font-weight:800}.github-mark{display:inline-grid;place-items:center;width:24px;height:24px;border-radius:999px;background:#fff;color:#5b6df6;font-size:10px;font-weight:800}.github-signin:hover,.local-signin button:hover{background:#4d5fe8}.github-signin:focus,.local-signin input:focus,.local-signin button:focus,.auth-tab:focus{outline:3px solid #7dd3fc;outline-offset:3px}.auth-divider{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:14px;margin:26px 0 24px;color:#e5e7eb;font-size:14px}.auth-divider:before,.auth-divider:after{content:'';height:1px;background:rgba(17,24,39,.30)}.local-signin{display:grid;gap:20px}.local-signin label{display:grid;gap:8px;color:#fff;font-size:14px;font-weight:800}.local-signin input{box-sizing:border-box;width:100%;min-height:60px;border:1px solid #454545;border-radius:8px;padding:12px 18px;font:16px inherit;color:#fff;background:rgba(27,27,27,.18)}.local-signin input::placeholder{color:#cbd5e1}.local-signin button{margin-top:12px}.empty{margin:0;color:#e5e7eb;font-size:14px;line-height:1.5}@media (max-width:620px){.login-shell{padding:24px 16px 36px}.hero-panel{min-height:300px;padding:24px;box-shadow:0 0 0 10px #1d1c24,0 0 0 20px #2f2f31}h1{font-size:26px}.github-signin,.local-signin button,.local-signin input{min-height:52px}}"
end

verb http/document(view)
  let snapshot = sync_snapshot(view)
  let payload = sync_snapshot_payload(view)
  let signature = sync_snapshot_signature(view, payload)
  let root = sync_snapshot_tree(view)
  let mount = sync_mount_node(view, snapshot[:revision], signature, root)
  let head = dom <head>
    <meta charset="utf-8" />
    <title>Mica MUD</title>
    <style>{dom_raw(string_concat(http/base_style(), http/login_style(), http/presence_style(), http/narrative_style()))}</style>
  </head>
  let body = dom <body>
    {mount}
    <script type="module">{dom_raw(http/bootstrap_script())}</script>
  </body>
  return to_xml([dom_raw("<!doctype html>"), dom <html>{head}{body}</html>])
end

verb http/base_style()
  return include_text("style.css")
end

verb http/login_style()
  return include_text("login.css")
end

verb http/presence_style()
  return include_text("presence.css")
end

verb http/narrative_style()
  return include_text("narrative.css")
end

verb http/bootstrap_script()
  return include_text("bootstrap.js")
end
