// Narrative/event-log composition for the server-owned MUD view.

verb ui/event_actor_node(value @ #identity, viewer)
  return ui/event_identity_node(value, viewer, false, "entity-button event-entity actor-entity")
end

verb ui/event_identity_node(value @ #identity, viewer, cap, class)
  let name = ui/actor_name(value)
  if value == viewer
    let label = "you"
    if cap
      label = "You"
    end
    return dom <strong class={class} data-entity={to_literal(value)}>{label}</strong>
  end

  return ui/entity_action_node("", value, string_concat("look ", name), name, class)
end

verb ui/event_identity_node(value @ #string, viewer, cap, class)
  let text = value
  if cap
    text = template/capitalize(text)
  end

  return dom <span class="event-entity">{text}</span>
end

verb ui/event_object_node(event, value @ #identity, viewer)
  return ui/event_identity_node(value, viewer, false, "entity-button event-entity")
end

verb ui/event_object_node(event, value @ #string, viewer)
  return dom <span class="event-quote">{value}</span>
end

verb ui/event_verb(actor, viewer, self, other)
  if actor == viewer
    return self
  end

  return other
end

verb ui/event_body_node(event, viewer)
  let source = event.event/source
  return ui/event_body_for(source, viewer)
end

verb ui/event_body_for(source, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_template_body_node(source @ #event<_>, viewer)
  let nodes = []
  let bindings = event/bindings(source)
  let template = event/template(source)
  for part in frob_value(template)
    nodes = [@nodes, @ui/event_template_value_nodes(source, part, bindings, viewer)]
  end

  return dom <div class="event-text">{@nodes}</div>
end

verb ui/event_template_value_nodes(source, value @ #template/substitution<_>, bindings @ #map, viewer)
  let nodes = []
  for part in frob_value(value)
    nodes = [@nodes, @ui/event_template_value_nodes(source, part, bindings, viewer)]
  end
  return nodes
end

verb ui/event_template_value_nodes(source, value @ #list, bindings @ #map, viewer)
  let nodes = []
  for part in value
    nodes = [@nodes, @ui/event_template_value_nodes(source, part, bindings, viewer)]
  end
  return nodes
end

verb ui/event_template_value_nodes(source, value, bindings @ #map, viewer)
  return ui/event_template_part_nodes(source, value, bindings, viewer)
end

verb ui/event_template_part_nodes(source, part, bindings @ #map, viewer)
  return [dom_text(template/render_part(part, bindings, viewer))]
end

verb ui/event_template_part_nodes(source, part @ #template/self_alt<_>, bindings @ #map, viewer)
  let data = frob_value(part)
  if bindings[:actor] == viewer
    return ui/event_template_value_nodes(source, data[:self], bindings, viewer)
  end

  return ui/event_template_value_nodes(source, data[:other], bindings, viewer)
end

verb ui/event_template_part_nodes(source, part @ #template/name<_>, bindings @ #map, viewer)
  let data = frob_value(part)
  let value = template/binding_value(bindings, data[:binding])
  if value == nothing
    return [dom_text("<no-binding>")]
  end

  if data[:binding] == :message
    return [ui/event_object_node(source, template/binding_value_text(value, viewer), viewer)]
  end

  if data[:binding] == :actor
    return [ui/event_identity_node(value, viewer, data[:cap], "entity-button event-entity actor-entity")]
  end

  return [ui/event_identity_node(value, viewer, data[:cap], "entity-button event-entity")]
end

verb ui/event_template_part_nodes(source, part @ #template/reference<_>, bindings @ #map, viewer)
  let data = frob_value(part)
  let value = template/binding_value(bindings, data[:binding])
  if value == nothing
    return [dom_text("<no-binding>")]
  end

  if data[:binding] == :location && value == viewer.locatedIn
    let text = "here"
    if data[:cap]
      text = "Here"
    end
    return [dom <span class="event-entity">{text}</span>]
  end

  let article = ""
  if value != viewer && ProperNoun(value) == false
    article = "the"
  end

  let cap_entity = data[:cap] && article == ""
  if article == ""
    return [ui/event_identity_node(value, viewer, cap_entity, "entity-button event-entity")]
  end

  if data[:cap]
    article = template/capitalize(article)
  end

  return [dom_text(string_concat(article, " ")), ui/event_identity_node(value, viewer, false, "entity-button event-entity")]
end

verb ui/event_template_part_nodes(source, part @ #template/article<_>, bindings @ #map, viewer)
  let data = frob_value(part)
  let value = template/binding_value(bindings, data[:binding])
  if value == nothing
    return [dom_text("<no-binding>")]
  end

  let name = template/binding_value_text(value, viewer)
  if data[:binding] == :location && value == viewer.locatedIn
    name = "here"
  end
  let article = ""
  if value != viewer && (data[:binding] != :location || value != viewer.locatedIn) && ProperNoun(value) == false
    if data[:article] == :the
      article = "the"
    elseif data[:article] == :a && Plural(value) == false
      article = template/article_for(name)
    end
  end

  let cap_entity = data[:cap] && article == ""
  if article == ""
    if data[:binding] == :location && value == viewer.locatedIn
      if cap_entity
        name = template/capitalize(name)
      end
      return [dom <span class="event-entity">{name}</span>]
    end
    return [ui/event_identity_node(value, viewer, cap_entity, "entity-button event-entity")]
  end

  if data[:cap]
    article = template/capitalize(article)
  end

  return [dom_text(string_concat(article, " ")), ui/event_identity_node(value, viewer, false, "entity-button event-entity")]
end

verb ui/event_body_for(source @ #event/movement<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/arrival<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/take<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/take_from<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/drop<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/put<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/say<_>, viewer)
  return ui/event_template_body_node(source, viewer)
end

verb ui/event_body_for(source @ #event/button<_>, viewer)
  let bindings = event/bindings(source)
  let target = bindings[:target]
  if target == nothing
    target = #red_button
  end
  return dom <div class="event-text">{ui/event_object_node(source, target, viewer)} gives one final cheerful ding.</div>
end

verb ui/event_class(source)
  let class = event/metadata(source, :class, nothing)
  if class != nothing
    return class
  end

  return "event-line"
end

verb ui/event_class(source @ #event/movement<_>)
  return "event-line movement"
end

verb ui/event_class(source @ #event/arrival<_>)
  return "event-line movement"
end

verb ui/event_class(source @ #event/take<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/take_from<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/drop<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/put<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/say<_>)
  return "event-line speech"
end

verb ui/event_class(source @ #event/button<_>)
  return "event-line alert"
end

verb ui/event_label(source)
  let label = event/metadata(source, :label, nothing)
  if label != nothing
    return label
  end

  return "system"
end

verb ui/event_label(source @ #event/movement<_>)
  return "movement"
end

verb ui/event_label(source @ #event/arrival<_>)
  return "movement"
end

verb ui/event_label(source @ #event/take<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/take_from<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/drop<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/put<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/say<_>)
  return "speech"
end

verb ui/event_label(source @ #event/button<_>)
  return "alert"
end

verb ui/event_meta_chip_node(label, value)
  return dom <span class="event-meta-chip">
    <span class="event-meta-label">{label}</span>
    <span class="event-meta-value">{value}</span>
  </span>
end

verb ui/event_meta_node(source, seq)
  let chips = [ui/event_meta_chip_node("kind", ui/event_label(source))]
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  if actor != nothing
    chips = [@chips, ui/event_meta_chip_node("actor", ui/actor_name(actor))]
  end

  let item = bindings[:item]
  if item != nothing
    chips = [@chips, ui/event_meta_chip_node("item", ui/actor_name(item))]
  end

  let container = bindings[:container]
  if container != nothing
    chips = [@chips, ui/event_meta_chip_node("container", ui/actor_name(container))]
  end

  let message = bindings[:message]
  if message != nothing
    chips = [@chips, ui/event_meta_chip_node("message", message)]
  end

  return dom <div class="event-meta">{@chips}</div>
end

verb ui/event_node(event)
  let seq = event.event/seq
  let source = event.event/source
  return dom <li data-sync-key={to_literal(event)} class={ui/event_class(source)}>
    <div class="event-line-main">
      <span class="event-kind">{ui/event_label(source)}</span>
      {ui/event_body_node(event, ui/current_actor())}
    </div>
  </li>
end

verb ui/latest_event_node(actor @ #player, revision)
  let latest = nothing
  let latest_seq = -1
  for found in event/Delivery(actor, ?event)
    let seq = found[:event].event/seq
    if seq < revision && seq > latest_seq
      latest = found[:event]
      latest_seq = seq
    end
  end

  if latest == nothing
    return dom <section id="latest-event" class="latest-event empty">
      <span class="muted">No events yet.</span>
    </section>
  end

  let source = latest.event/source
  return dom <section id="latest-event" class={string_concat("latest-event ", ui/event_label(source))}>
    <div class="latest-heading">
      <strong>Latest</strong>
      <span class="event-kind">{ui/event_label(source)}</span>
    </div>
    <div class="latest-body">{ui/event_body_node(latest, actor)}</div>
    {ui/event_meta_node(source, latest_seq)}
  </section>
end

verb ui/narrative_node(actor @ #player, revision, limit)
  let events = []
  let count = 0

  for found in event/Delivery(actor, ?event)
    let seq = found[:event].event/seq
    if seq < revision
      count = count + 1
    end
  end

  if count == 0
    events = [dom <li class="muted">The room is quiet.</li>]
  else
    let first_rendered = 0
    if count > limit
      first_rendered = count - limit
    end

    let rendered = 0
    let index = 0
    for found in event/Delivery(actor, ?event)
      let seq = found[:event].event/seq
      if seq < revision
        if index >= first_rendered
          events = [@events, ui/event_node(found[:event])]
          rendered = rendered + 1
        end
        index = index + 1
      end
    end
  end

  let heading = dom <div class="narrative-heading">
    <h2>Narrative</h2>
  </div>

  let children = []
  if count > limit
    children = [dom <form class="narrative-older-form" data-sync-event="submit" data-sync-action="mud_load_older_events">
      <button class="mini-button">{string_concat("Load older (", to_literal(count - limit), " more)")}</button>
    </form>]
  end

  if count > limit
    children = [@children, dom <ul class="event-list" data-sync-on-viewport-top="mud_load_older_events" data-sync-viewport-threshold="24">{@events}</ul>]
  else
    children = [@children, dom <ul class="event-list">{@events}</ul>]
  end
  return dom <section id="narrative" class="panel narrative" aria-live="polite" data-sync-follow="bottom" data-sync-stable-top="true">
    {heading}
    {@children}
  </section>
end
