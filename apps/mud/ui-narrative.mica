// Narrative/event-log composition for the server-owned MUD view.

verb ui/event_actor_node(value @ #identity, viewer)
  let name = ui/actor_name(value)
  if value == viewer
    return dom_element("strong", {:class -> "event-entity", "data-entity" -> to_literal(value)}, [dom_text("you")])
  end

  return ui/entity_action_node("", value, string_concat("look ", name), name, "entity-button event-entity actor-entity")
end

verb ui/event_object_node(event, value @ #identity, viewer)
  let name = ui/actor_name(value)
  return ui/entity_action_node("", value, string_concat("look ", name), name, "entity-button event-entity")
end

verb ui/event_object_node(event, value @ #string, viewer)
  return dom_element("span", {:class -> "event-quote"}, [dom_text(value)])
end

verb ui/event_verb(actor, viewer, self, other)
  if actor == viewer
    return self
  end

  return other
end

verb ui/event_body_node(event, viewer)
  let source = one event/Source(event, ?source)
  if source == nothing
    return dom_element("div", {:class -> "event-text"}, [dom_text(one event/Text(event, ?text))])
  end

  return ui/event_body_for(source, viewer)
end

verb ui/event_body_for(source, viewer)
  return dom_element("div", {:class -> "event-text"}, [dom_text(event/render(source, viewer))])
end

verb ui/event_body_for(source @ #event/movement<_>, viewer)
  let actor = event/bindings(source)[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " move away.", " moves away."))])
end

verb ui/event_body_for(source @ #event/arrival<_>, viewer)
  let actor = event/bindings(source)[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " arrive.", " arrives."))])
end

verb ui/event_body_for(source @ #event/take<_>, viewer)
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " take ", " takes ")), ui/event_object_node(source, bindings[:item], viewer), dom_text(".")])
end

verb ui/event_body_for(source @ #event/take_from<_>, viewer)
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " take ", " takes ")), ui/event_object_node(source, bindings[:item], viewer), dom_text(" from "), ui/event_object_node(source, bindings[:container], viewer), dom_text(".")])
end

verb ui/event_body_for(source @ #event/drop<_>, viewer)
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " drop ", " drops ")), ui/event_object_node(source, bindings[:item], viewer), dom_text(".")])
end

verb ui/event_body_for(source @ #event/put<_>, viewer)
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " put ", " puts ")), ui/event_object_node(source, bindings[:item], viewer), dom_text(" in "), ui/event_object_node(source, bindings[:container], viewer), dom_text(".")])
end

verb ui/event_body_for(source @ #event/say<_>, viewer)
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  return dom_element("div", {:class -> "event-text"}, [ui/event_actor_node(actor, viewer), dom_text(ui/event_verb(actor, viewer, " say, ", " says, ")), dom_element("span", {:class -> "event-quote"}, [dom_text(string_concat("\"", bindings[:message], "\""))])])
end

verb ui/event_body_for(source @ #event/button<_>, viewer)
  return dom_element("div", {:class -> "event-text"}, [ui/event_object_node(source, #red_button, viewer), dom_text(" gives one final cheerful ding.")])
end

verb ui/event_class(source)
  return "event-line"
end

verb ui/event_class(source @ #event/movement<_>)
  return "event-line movement"
end

verb ui/event_class(source @ #event/arrival<_>)
  return "event-line movement"
end

verb ui/event_class(source @ #event/take<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/take_from<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/drop<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/put<_>)
  return "event-line transfer"
end

verb ui/event_class(source @ #event/say<_>)
  return "event-line speech"
end

verb ui/event_class(source @ #event/button<_>)
  return "event-line alert"
end

verb ui/event_label(source)
  return "system"
end

verb ui/event_label(source @ #event/movement<_>)
  return "movement"
end

verb ui/event_label(source @ #event/arrival<_>)
  return "movement"
end

verb ui/event_label(source @ #event/take<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/take_from<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/drop<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/put<_>)
  return "transfer"
end

verb ui/event_label(source @ #event/say<_>)
  return "speech"
end

verb ui/event_label(source @ #event/button<_>)
  return "alert"
end

verb ui/event_meta_chip_node(label, value)
  return dom_element("span", {:class -> "event-meta-chip"}, [dom_element("span", {:class -> "event-meta-label"}, [dom_text(label)]), dom_element("span", {:class -> "event-meta-value"}, [dom_text(value)])])
end

verb ui/event_meta_node(source, seq)
  let chips = [ui/event_meta_chip_node("seq", to_literal(seq)), ui/event_meta_chip_node("kind", ui/event_label(source))]
  let bindings = event/bindings(source)
  let actor = bindings[:actor]
  if actor != nothing
    chips = [@chips, ui/event_meta_chip_node("actor", ui/actor_name(actor))]
  end

  let item = bindings[:item]
  if item != nothing
    chips = [@chips, ui/event_meta_chip_node("item", ui/actor_name(item))]
  end

  let container = bindings[:container]
  if container != nothing
    chips = [@chips, ui/event_meta_chip_node("container", ui/actor_name(container))]
  end

  let message = bindings[:message]
  if message != nothing
    chips = [@chips, ui/event_meta_chip_node("message", message)]
  end

  return dom_element("div", {:class -> "event-meta"}, chips)
end

verb ui/event_node(event)
  let seq = one event/Seq(event, ?seq)
  let text = one event/Text(event, ?text)
  let source = one event/Source(event, ?source)
  if source == nothing
    return dom_element("li", {"data-sync-key" -> to_literal(event), :class -> "event-line"}, [dom_element("span", {:class -> "event-seq"}, [dom_text(string_concat("#", to_literal(seq)))]), dom_text(text)])
  end

  let badge = dom_element("span", {:class -> "event-kind"}, [dom_text(ui/event_label(source))])
  return dom_element("li", {"data-sync-key" -> to_literal(event), :class -> ui/event_class(source)}, [dom_element("div", {:class -> "event-line-main"}, [dom_element("span", {:class -> "event-seq"}, [dom_text(string_concat("#", to_literal(seq)))]), badge, ui/event_body_node(event, ui/current_actor())])])
end

verb ui/latest_event_node(actor @ #player, revision)
  let latest = nothing
  let latest_seq = -1
  for found in event/Delivery(actor, ?event)
    let seq = one event/Seq(found[:event], ?seq)
    if seq < revision && seq > latest_seq
      latest = found[:event]
      latest_seq = seq
    end
  end

  if latest == nothing
    return dom_element("section", {:id -> "latest-event", :class -> "latest-event empty"}, [dom_element("span", {:class -> "muted"}, [dom_text("No events yet.")])])
  end

  let text = one event/Text(latest, ?text)
  let source = one event/Source(latest, ?source)
  if source == nothing
    return dom_element("section", {:id -> "latest-event", :class -> "latest-event system"}, [dom_element("div", {:class -> "latest-heading"}, [dom_element("strong", {}, [dom_text("Latest")]), dom_element("span", {:class -> "event-kind"}, [dom_text("system")])]), dom_element("div", {:class -> "latest-body"}, [dom_text(text)])])
  end

  return dom_element("section", {:id -> "latest-event", :class -> string_concat("latest-event ", ui/event_label(source))}, [dom_element("div", {:class -> "latest-heading"}, [dom_element("strong", {}, [dom_text("Latest")]), dom_element("span", {:class -> "event-kind"}, [dom_text(ui/event_label(source))])]), dom_element("div", {:class -> "latest-body"}, [ui/event_body_node(latest, actor)]), ui/event_meta_node(source, latest_seq)])
end

verb ui/narrative_node(actor @ #player, revision, limit)
  let events = []
  let count = 0

  for found in event/Delivery(actor, ?event)
    let seq = one event/Seq(found[:event], ?seq)
    if seq < revision
      count = count + 1
    end
  end

  if count == 0
    events = [dom_element("li", {:class -> "muted"}, [dom_text("The room is quiet.")])]
  else
    let first_rendered = 0
    if count > limit
      first_rendered = count - limit
    end

    let rendered = 0
    let index = 0
    for found in event/Delivery(actor, ?event)
      let seq = one event/Seq(found[:event], ?seq)
      if seq < revision
        if index >= first_rendered
          events = [@events, ui/event_node(found[:event])]
          rendered = rendered + 1
        end
        index = index + 1
      end
    end
  end

  let heading = dom_element("div", {:class -> "narrative-heading"}, [dom_element("h2", {}, [dom_text("Narrative")]), dom_element("span", {:class -> "narrative-count"}, [dom_text(to_literal(count)), dom_text(" events")])])

  let children = []
  if count > limit
    children = [dom_element("form", {:class -> "narrative-older-form", "data-sync-event" -> "submit", "data-sync-action" -> "mud_load_older_events"}, [dom_element("button", {:class -> "mini-button"}, [dom_text(string_concat("Load older (", to_literal(count - limit), " more)"))])])]
  end

  let list_attrs = {:class -> "event-list"}
  if count > limit
    list_attrs = {:class -> "event-list", "data-sync-on-viewport-top" -> "mud_load_older_events", "data-sync-viewport-threshold" -> "24"}
  end
  children = [@children, dom_element("ul", list_attrs, events)]
  return dom_element("section", {:id -> "narrative", :class -> "panel narrative", "aria-live" -> "polite", "data-sync-follow" -> "bottom", "data-sync-stable-top" -> "true"}, [heading, @children])
end
