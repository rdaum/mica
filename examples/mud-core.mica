Exit(from, direction, to) :-
  BidirectionalExit(from, direction, reverse, to)

Exit(to, reverse, from) :-
  BidirectionalExit(from, direction, reverse, to)

Within(item, place) :-
  LocatedIn(item, place)

Within(item, place) :-
  LocatedIn(item, container),
  Within(container, place)

Contents(place, item) :-
  Within(item, place)

Carrying(actor, item) :-
  LocatedIn(item, actor)

CanSee(actor, room) :-
  LocatedIn(actor, room)

CanSee(actor, item) :-
  LocatedIn(actor, room),
  Within(item, room)

CanSee(actor, item) :-
  Carrying(actor, item)

PresentActor(room, actor) :-
  Delegates(actor, #player, depth),
  LocatedIn(actor, room)

ParserName(obj, name) :-
  ParserNoun(obj, name)

ParserName(obj, parser_alias) :-
  ParserAlias(obj, parser_alias)

VisibleTo(actor, obj) :-
  CanSee(actor, obj)

NameMatchable(actor, obj) :-
  VisibleTo(actor, obj),
  TrustedForNameParsing(actor, obj)

CommandGrammarSource(actor, provider) :-
  TrustedForCommandGrammar(actor, provider)

CommandHandlerScope(actor, actor) :-
  TrustedForCommandGrammar(actor, actor)

CommandHandlerScope(actor, room) :-
  LocatedIn(actor, room)

verb emit_room_event(room @ #room, event @ #event<_>)
  for found in PresentActor(room, ?listener)
    let listener = found[:listener]
    emit(listener, render_event(event, listener))
  end

  return true
end

verb emit_room_event_except(room @ #room, skipped @ #identity, event @ #event<_>)
  for found in PresentActor(room, ?listener)
    let listener = found[:listener]
    if listener != skipped
      emit(listener, render_event(event, listener))
    end
  end

  return true
end

verb look(actor @ #player)
  let room = one LocatedIn(actor, ?room)
  emit(actor, one Description(room, ?text))

  for found in LocatedIn(?item, room)
    let item = found[:item]
    let text = one Description(item, ?text)
    if item != actor && text != nothing
      emit(actor, text)
    end
  end

  return true
end

verb examine(actor @ #player, target @ #thing)
  if CanSee(actor, target)
    emit(actor, one Description(target, ?text))
    return true
  end

  emit(actor, "I do not see that.")
  return false
end

verb look_in(actor @ #player, target @ #container)
  if CanSee(actor, target) == false
    emit(actor, "I do not see that.")
    return false
  end

  let found_any = false
  for found in LocatedIn(?item, target)
    let item = found[:item]
    let text = one Description(item, ?text)
    if text != nothing
      found_any = true
      emit(actor, text)
    end
  end

  if found_any == false
    emit(actor, "It is empty.")
  end

  return true
end

verb north(actor @ #player)
  return :go(actor: actor, direction: :north, leave: "{Actor} {walk|walks} north.", arrive: "{Actor} {arrive|arrives} from the south.")
end

verb south(actor @ #player)
  return :go(actor: actor, direction: :south, leave: "{Actor} {walk|walks} south.", arrive: "{Actor} {arrive|arrives} from the north.")
end

verb up(actor @ #player)
  return :go(actor: actor, direction: :up, leave: "{Actor} {climb|climbs} up.", arrive: "{Actor} {arrive|arrives} from below.")
end

verb down(actor @ #player)
  return :go(actor: actor, direction: :down, leave: "{Actor} {climb|climbs} down.", arrive: "{Actor} {arrive|arrives} from above.")
end

verb go(actor @ #player, direction, leave, arrive)
  let room = one LocatedIn(actor, ?room)
  let destination = one Exit(room, direction, ?destination)

  if destination == nothing
    emit(actor, "You cannot go that way.")
    return false
  end

  let bindings = {:actor -> actor}
  :emit_room_event(room: room, event: narrative_event(#movement_event, leave, bindings))
  retract LocatedIn(actor, _)
  assert LocatedIn(actor, destination)
  :emit_room_event_except(room: destination, skipped: actor, event: narrative_event(#arrival_event, arrive, bindings))
  emit(actor, one Description(destination, ?text))
  return true
end

verb get(actor @ #player, item @ #thing)
  if Carrying(actor, item)
    emit(actor, "You already have that.")
    return false
  end

  if Portable(item) && CanSee(actor, item)
    let room = one LocatedIn(actor, ?room)
    retract LocatedIn(item, _)
    assert LocatedIn(item, actor)
    :emit_room_event(room: room, event: narrative_event(#take_event, "{Actor} {take|takes} {the item}.", {:actor -> actor, :item -> item}))
    return true
  end

  emit(actor, "You cannot take that.")
  return false
end

verb get_from(actor @ #player, item @ #thing, container @ #container)
  if Carrying(actor, item)
    emit(actor, "You already have that.")
    return false
  end

  if CanSee(actor, container) == false
    emit(actor, "I do not see that.")
    return false
  end

  if LocatedIn(item, container) && Portable(item)
    let room = one LocatedIn(actor, ?room)
    retract LocatedIn(item, _)
    assert LocatedIn(item, actor)
    :emit_room_event(room: room, event: narrative_event(#take_from_event, "{Actor} {take|takes} {the item} from {the container}.", {:actor -> actor, :item -> item, :container -> container}))
    return true
  end

  emit(actor, "That is not in there.")
  return false
end

verb drop(actor @ #player, item @ #thing)
  let room = one LocatedIn(actor, ?room)

  if Carrying(actor, item)
    retract LocatedIn(item, _)
    assert LocatedIn(item, room)
    :emit_room_event(room: room, event: narrative_event(#drop_event, "{Actor} {drop|drops} {the item}.", {:actor -> actor, :item -> item}))
    return true
  end

  emit(actor, "You are not carrying that.")
  return false
end

verb put(actor @ #player, item @ #thing, container @ #container)
  if Carrying(actor, item) && CanSee(actor, container)
    let room = one LocatedIn(actor, ?room)
    retract LocatedIn(item, _)
    assert LocatedIn(item, container)
    :emit_room_event(room: room, event: narrative_event(#put_event, "{Actor} {put|puts} {the item} in {the container}.", {:actor -> actor, :item -> item, :container -> container}))
    return true
  end

  emit(actor, "You are not carrying that.")
  return false
end

verb say(actor @ #player, message)
  let room = one LocatedIn(actor, ?room)
  let event = narrative_event(#say_event, "{Actor} {say|says}, \"{message}\"", {:actor -> actor, :message -> message})
  :emit_room_event(room: room, event: event)
  return true
end
