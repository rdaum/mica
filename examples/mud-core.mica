assert CanInvoke(#alice, :command)
assert CanInvoke(#alice, :match_object)
assert CanInvoke(#alice, :bind_command_pattern)
assert CanInvoke(#alice, :look)
assert CanInvoke(#alice, :examine)
assert CanInvoke(#alice, :look_in)
